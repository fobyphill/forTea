#
#===============================================================================
#==TABLE no 607    : Регистр (Дв.) Замена
# Name    |Descr                         |SQLTableNam|RecordLock
T=RA1677  |Регистр (Дв.) Замена          |RA1677     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=IDDOC                 |ID Document's       |C   |9     |0        
F=LINENO_               |LineNo              |S   |0     |0        
F=ACTNO                 |Action No           |I   |0     |0        
F=DEBKRED               |Flag Debet/Kredit   |L   |0     |0        
F=IDDOCDEF              |ID Def Document     |I   |0     |0        
F=DATE_TIME_IDDOC       |Date+Time+IDDoc     |C   |23    |0        
F=SP1678                |(P)ТоварС           |C   |9     |0        
F=SP1679                |(P)ТоварНа          |C   |9     |0        
F=SP9146                |(P)Док              |C   |13    |0        
F=SP1680                |(P)Флаг             |N   |1     |0        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA1677                      |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
I=VIA1678                        |VIA1678       |1     |SP1678,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
I=VIA1679                        |VIA1679       |1     |SP1679,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA1677_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(9), @p2 CHAR(13), @f0 NUMERIC(1, 0)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA1677 CURSOR FOR SELECT DEBKRED, SP1678, SP1679, SP9146, SP1680  FROM RA1677 WHERE IDDOC=@IdDoc
OPEN Cur_RA1677
FETCH NEXT FROM Cur_RA1677 INTO @DebetCredit, @p0, @p1, @p2, @f0
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG1677_Change @Period, @p0, @p1, @p2, @f0
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG1677_Change @CurPeriod, @p0, @p1, @p2, @f0
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG1677_Change @Period, @p0, @p1, @p2, @f0
    END

    FETCH NEXT FROM Cur_RA1677 INTO @DebetCredit, @p0, @p1, @p2, @f0
END
CLOSE Cur_RA1677
DEALLOCATE Cur_RA1677
\}
