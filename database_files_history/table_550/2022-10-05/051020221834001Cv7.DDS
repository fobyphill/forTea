# Name    |Descr                         |SQLTableNam|RecordLock
T=RG2867  |Регистр НаличиеТовараНаОстатка|RG2867     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP2868                |(P)Товар            |C   |9     |0        
F=SP2869                |(P)Был              |N   |1     |0        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG2867                      |PERIOD+PROP   |1     |PERIOD,SP2868                                               |1          
