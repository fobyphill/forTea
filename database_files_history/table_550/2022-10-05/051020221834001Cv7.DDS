P=_1sp_RG5815_TLockX            |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RG5815(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 670    : Регистр Статус
# Name    |Descr                         |SQLTableNam|RecordLock
T=RG5815  |Регистр Статус                |RG5815     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP5811                |(P)Клиент           |C   |9     |0        
F=SP5812                |(P)Документ         |C   |13    |0        
F=SP5813                |(P)ДокОснование     |C   |13    |0        
F=SP5814                |(P)Статус           |N   |9     |4        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG5815                      |PERIOD+PROP   |1     |PERIOD,SP5811,SP5812,SP5813                                 |1          
I=VIA5812                        |VIA5812       |0     |PERIOD,SP5812                                               |0          
I=VIA5813                        |VIA5813       |0     |PERIOD,SP5813                                               |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG5815_Change            |              |@per D,@p1 C(9),@p2 C(13),@p3 C(13),@p4 N(9,4)|{\
Set Nocount On
Update RG5815
  set SP5814=Case When ABS(SP5814+@p4)>99999.9999 Then 99999.9999 Else SP5814+@p4 End
  where PERIOD=@per AND SP5811=@p1 AND SP5812=@p2 AND SP5813=@p3
if @@ROWCOUNT=0
    insert into RG5815 values(@per,@p1,@p2,@p3,@p4)
\}
