I=PK_RA1859                      |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
I=DATETIME                       |Date+Time+IDOC|1     |DATE_TIME_IDDOC,LINENO_,ACTNO                               |0          
I=VIA1860                        |VIA1860       |1     |SP1860,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA1859_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(9), @f0 NUMERIC(14, 2), @f1 NUMERIC(14, 2)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA1859 CURSOR FOR SELECT DEBKRED, SP1860, SP2724, SP1861, SP2729  FROM RA1859 WHERE IDDOC=@IdDoc
OPEN Cur_RA1859
FETCH NEXT FROM Cur_RA1859 INTO @DebetCredit, @p0, @p1, @f0, @f1
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG1859_Change @Period, @p0, @p1, @f0, @f1
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG1859_Change @CurPeriod, @p0, @p1, @f0, @f1
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG1859_Change @Period, @p0, @p1, @f0, @f1
    END

    FETCH NEXT FROM Cur_RA1859 INTO @DebetCredit, @p0, @p1, @f0, @f1
END
CLOSE Cur_RA1859
DEALLOCATE Cur_RA1859
\}
