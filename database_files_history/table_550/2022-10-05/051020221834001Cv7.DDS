# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA750_TLockX             |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RA750(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 601    : Регистр (Дв.) Договора
# Name    |Descr                         |SQLTableNam|RecordLock
T=RA750   |Регистр (Дв.) Договора        |RA750      |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=IDDOC                 |ID Document's       |C   |9     |0        
F=LINENO_               |LineNo              |S   |0     |0        
F=ACTNO                 |Action No           |I   |0     |0        
F=DEBKRED               |Flag Debet/Kredit   |L   |0     |0        
F=IDDOCDEF              |ID Def Document     |I   |0     |0        
F=DATE_TIME_IDDOC       |Date+Time+IDDoc     |C   |23    |0        
F=SP752                 |(P)Клиент           |C   |9     |0        
F=SP753                 |(P)Документ         |C   |13    |0        
F=SP1242                |(P)Договор          |N   |14    |4        
F=SP930                 |(P)Ожидается        |N   |14    |4        
F=SP931                 |(P)Зарезервировано  |N   |14    |4        
F=SP934                 |(P)НаХранении       |N   |14    |4        
F=SP7710                |(P)Потребность      |N   |14    |4        
F=SP7711                |(P)РезервОжидания   |N   |14    |4        
F=SP7712                |(P)ВПути            |N   |14    |4        
F=SP2576                |(P)Получено         |N   |14    |4        
F=SP2577                |(P)Отдано           |N   |14    |4        
F=SP2578                |(P)ПолученоВО       |N   |14    |2        
F=SP2579                |(P)ОтданоВО         |N   |14    |2        
F=SP3162                |(P)ВидДоговора      |C   |9     |0        
F=SP9203                |(P)КурсоваяРазница  |N   |14    |2        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA750                       |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
I=DATETIME                       |Date+Time+IDOC|1     |DATE_TIME_IDDOC,LINENO_,ACTNO                               |0          
I=VIA753                         |VIA753        |1     |SP753,DATE_TIME_IDDOC,LINENO_,ACTNO                         |0          
I=VIA3162                        |VIA3162       |1     |SP3162,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA750_ClearRecalcDocActs |              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(13), @f0 NUMERIC(14, 4), @f1 NUMERIC(14, 4), @f2 NUMERIC(14, 4), @f3 NUMERIC(14, 4), @f4 NUMERIC(14, 4), @f5 NUMERIC(14, 4), @f6 NUMERIC(14, 4)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA750 CURSOR FOR SELECT DEBKRED, SP752, SP753, SP1242, SP930, SP931, SP934, SP7710, SP7711, SP7712  FROM RA750 WHERE IDDOC=@IdDoc
OPEN Cur_RA750
FETCH NEXT FROM Cur_RA750 INTO @DebetCredit, @p0, @p1, @f0, @f1, @f2, @f3, @f4, @f5, @f6
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4, @f5=-@f5, @f6=-@f6
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG750_Change @Period, @p0, @p1, @f0, @f1, @f2, @f3, @f4, @f5, @f6
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG750_Change @CurPeriod, @p0, @p1, @f0, @f1, @f2, @f3, @f4, @f5, @f6
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG750_Change @Period, @p0, @p1, @f0, @f1, @f2, @f3, @f4, @f5, @f6
    END

    FETCH NEXT FROM Cur_RA750 INTO @DebetCredit, @p0, @p1, @f0, @f1, @f2, @f3, @f4, @f5, @f6
END
CLOSE Cur_RA750
DEALLOCATE Cur_RA750
\}
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA750_WriteDocAct        |              |@IdDoc C(9), @LineNo S, @ActNo I, @DebetCredit L, @IdDocDef I, @DateTimeIdDoc C(23), @p0 C(9), @p1 C(13), @f0 N(14,4), @f1 N(14,4), @f2 N(14,4), @f3 N(14,4), @f4 N(14,4), @f5 N(14,4), @f6 N(14,4), @g0 N(14,4), @g1 N(14,4), @g2 N(14,2), @g3 N(14,2), @g4 C(9), @g5 N(14,2), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM

EXECUTE _1sp_GetBeginOfPeriod @PeriodTA, @SnapShotPeriod, @PeriodTA OUTPUT
INSERT INTO RA750 VALUES(@IdDoc, @LineNo, @ActNo, @DebetCredit,@IdDocDef,@DateTimeIdDoc, @p0, @p1, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @g0, @g1, @g2, @g3, @g4, @g5)
IF @DebetCredit=1
    SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4, @f5=-@f5, @f6=-@f6
IF @RepeatToTM=1 BEGIN
    SELECT @Period=@CurPeriod
    WHILE @Period<=@PeriodTA BEGIN
        EXECUTE _1sp_RG750_Change @Period, @p0, @p1, @f0, @f1, @f2, @f3, @f4, @f5, @f6
        EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
    END
END
ELSE
    EXECUTE _1sp_RG750_Change @CurPeriod, @p0, @p1, @f0, @f1, @f2, @f3, @f4, @f5, @f6
IF @SaveTurnsWithMonth=1 BEGIN
    EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
    EXECUTE _1sp_RG750_Change @Period, @p0, @p1, @f0, @f1, @f2, @f3, @f4, @f5, @f6
END
\}
#
#===============================================================================
#==PROCEDURE EscalateTLock
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG2814_TLock             |EscalateTLock |                                        |set nocount on declare @i integer select @i=1 from RG2814(TABLOCK HOLDLOCK) where 0=1
#
#===============================================================================
#==PROCEDURE EscalateTLockX
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG2814_TLockX            |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RG2814(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 602    : Регистр Заказы
# Name    |Descr                         |SQLTableNam|RecordLock
T=RG2814  |Регистр Заказы                |RG2814     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP2817                |(P)Заказ            |C   |9     |0        
F=SP2815                |(P)Товар            |C   |9     |0        
F=SP2816                |(P)Количество       |N   |14    |3        
F=SP3074                |(P)КоличествоВсего  |N   |14    |3        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG2814                      |PERIOD+PROP   |1     |PERIOD,SP2817,SP2815                                        |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG2814_Change            |              |@per D,@p1 C(9),@p2 C(9),@p3 N(14,3),@p4 N(14,3)|{\
Set Nocount On
Update RG2814
  set SP2816=Case When ABS(SP2816+@p3)>99999999999.999 Then 99999999999.999 Else SP2816+@p3 End,SP3074=Case When ABS(SP3074+@p4)>99999999999.999 Then 99999999999.999 Else SP3074+@p4 End
  where PERIOD=@per AND SP2817=@p1 AND SP2815=@p2
if @@ROWCOUNT=0
    insert into RG2814 values(@per,@p1,@p2,@p3,@p4)
\}
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG2814_Select            |              |@per D,@p1 C(9),@p2 C(9),@p3 N(14,3) O,@p4 N(14,3) O|Select @p3=SP2816,@p4=SP3074 from RG2814 where PERIOD=@per AND SP2817=@p1 AND SP2815=@p2
#
#===============================================================================
#==PROCEDURE EscalateTLock
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA2814_TLock             |EscalateTLock |                                        |set nocount on declare @i integer select @i=1 from RA2814(TABLOCK HOLDLOCK) where 0=1
