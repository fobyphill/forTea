#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG12439_Change           |              |@per D,@p1 C(13),@p2 C(13),@p3 C(9),@p4 C(9),@p5 C(9),@p6 C(13),@p7 N(14,4),@p8 N(14,4),@p9 N(14,4),@p10 N(14,4),@p11 N(14,4),@p12 N(14,4)|{\
Set Nocount On
Update RG12439
  set SP12434=Case When ABS(SP12434+@p7)>9999999999.9999 Then 9999999999.9999 Else SP12434+@p7 End,SP12834=Case When ABS(SP12834+@p8)>9999999999.9999 Then 9999999999.9999 Else SP12834+@p8 End,SP12835=Case When ABS(SP12835+@p9)>9999999999.9999 Then 9999999999.9999 Else SP12835+@p9 End,SP12437=Case When ABS(SP12437+@p10)>9999999999.9999 Then 9999999999.9999 Else SP12437+@p10 End,SP12438=Case When ABS(SP12438+@p11)>9999999999.9999 Then 9999999999.9999 Else SP12438+@p11 End,SP13129=Case When ABS(SP13129+@p12)>9999999999.9999 Then 9999999999.9999 Else SP13129+@p12 End
  where PERIOD=@per AND SP12433=@p1 AND SP12953=@p2 AND SP12818=@p3 AND SP12817=@p4 AND SP12816=@p5 AND SP12833=@p6
if @@ROWCOUNT=0
    insert into RG12439 values(@per,@p1,@p2,@p3,@p4,@p5,@p6,@p7,@p8,@p9,@p10,@p11,@p12)
