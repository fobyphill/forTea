#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH5807_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,2) 
SELECT @Sum0=COALESCE(SUM(SP5805),0) FROM DT5807 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>999999999999.99 SELECT @Sum0=999999999999.99*SIGN(@Sum0)
UPDATE DH5807 SET SP5805=@Sum0 WHERE IDDOC=@IdDoc
\}
