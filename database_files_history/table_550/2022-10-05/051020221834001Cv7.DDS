#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA6899_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @p1 CHAR(9), @p2 CHAR(9), @p3 NUMERIC(5, 2), @p4 CHAR(23), @f0 NUMERIC(14, 4)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA6899 CURSOR FOR SELECT DEBKRED, SP6893, SP6894, SP6895, SP6896, SP6897, SP6898  FROM RA6899 WHERE IDDOC=@IdDoc
OPEN Cur_RA6899
FETCH NEXT FROM Cur_RA6899 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @f0
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG6899_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG6899_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @f0
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG6899_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0
    END

    FETCH NEXT FROM Cur_RA6899 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @f0
END
CLOSE Cur_RA6899
DEALLOCATE Cur_RA6899
\}
