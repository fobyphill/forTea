#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH6640_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,2),@Sum1 NUMERIC(28,2) 
SELECT @Sum0=COALESCE(SUM(SP6638),0),@Sum1=COALESCE(SUM(SP6744),0) FROM DT6640 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>999999999999.99 SELECT @Sum0=999999999999.99*SIGN(@Sum0)
    IF ABS(@Sum1)>999999999999.99 SELECT @Sum1=999999999999.99*SIGN(@Sum1)
UPDATE DH6640 SET SP6638=@Sum0,SP6744=@Sum1 WHERE IDDOC=@IdDoc
\}
#
