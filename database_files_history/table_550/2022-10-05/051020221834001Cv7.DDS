P=_1sp_RA796_TLockX             |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RA796(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 597    : Регистр (Дв.) Банки
# Name    |Descr                         |SQLTableNam|RecordLock
T=RA796   |Регистр (Дв.) Банки           |RA796      |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=IDDOC                 |ID Document's       |C   |9     |0        
F=LINENO_               |LineNo              |S   |0     |0        
F=ACTNO                 |Action No           |I   |0     |0        
F=DEBKRED               |Flag Debet/Kredit   |L   |0     |0        
F=IDDOCDEF              |ID Def Document     |I   |0     |0        
F=DATE_TIME_IDDOC       |Date+Time+IDDoc     |C   |23    |0        
F=SP797                 |(P)Фирма            |C   |9     |0        
F=SP1630                |(P)Счет             |C   |9     |0        
F=SP800                 |(P)Сумма            |N   |14    |2        
F=SP9870                |(P)Пустой           |N   |10    |0        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA796                       |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
I=VIA797                         |VIA797        |1     |SP797,DATE_TIME_IDDOC,LINENO_,ACTNO                         |0          
I=VIA1630                        |VIA1630       |1     |SP1630,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA796_ClearRecalcDocActs |              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(9), @f0 NUMERIC(14, 2)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA796 CURSOR FOR SELECT DEBKRED, SP797, SP1630, SP800  FROM RA796 WHERE IDDOC=@IdDoc
OPEN Cur_RA796
FETCH NEXT FROM Cur_RA796 INTO @DebetCredit, @p0, @p1, @f0
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG796_Change @Period, @p0, @p1, @f0
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG796_Change @CurPeriod, @p0, @p1, @f0
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG796_Change @Period, @p0, @p1, @f0
    END

    FETCH NEXT FROM Cur_RA796 INTO @DebetCredit, @p0, @p1, @f0
END
CLOSE Cur_RA796
DEALLOCATE Cur_RA796
\}
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA796_WriteDocAct        |              |@IdDoc C(9), @LineNo S, @ActNo I, @DebetCredit L, @IdDocDef I, @DateTimeIdDoc C(23), @p0 C(9), @p1 C(9), @f0 N(14,2), @g0 N(10), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM

EXECUTE _1sp_GetBeginOfPeriod @PeriodTA, @SnapShotPeriod, @PeriodTA OUTPUT
INSERT INTO RA796 VALUES(@IdDoc, @LineNo, @ActNo, @DebetCredit,@IdDocDef,@DateTimeIdDoc, @p0, @p1, @f0, @g0)
IF @DebetCredit=1
    SELECT @f0=-@f0
IF @RepeatToTM=1 BEGIN
    SELECT @Period=@CurPeriod
    WHILE @Period<=@PeriodTA BEGIN
        EXECUTE _1sp_RG796_Change @Period, @p0, @p1, @f0
        EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
    END
END
ELSE
    EXECUTE _1sp_RG796_Change @CurPeriod, @p0, @p1, @f0
IF @SaveTurnsWithMonth=1 BEGIN
    EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
    EXECUTE _1sp_RG796_Change @Period, @p0, @p1, @f0
END
\}
