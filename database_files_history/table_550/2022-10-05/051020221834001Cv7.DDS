#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH11918_UpdateTotals     |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,3),@Sum1 NUMERIC(28,2),@Sum2 NUMERIC(28,2),@Sum3 NUMERIC(28,3),@Sum4 NUMERIC(28,3),@Sum5 NUMERIC(28,3),@Sum6 NUMERIC(28,3),@Sum7 NUMERIC(28,3),@Sum8 NUMERIC(28,3),@Sum9 NUMERIC(28,3),@Sum10 NUMERIC(28,3),@Sum11 NUMERIC(28,3) 
SELECT @Sum0=COALESCE(SUM(SP11884),0),@Sum1=COALESCE(SUM(SP11885),0),@Sum2=COALESCE(SUM(SP11886),0),@Sum3=COALESCE(SUM(SP11899),0),@Sum4=COALESCE(SUM(SP11900),0),@Sum5=COALESCE(SUM(SP11902),0),@Sum6=COALESCE(SUM(SP11905),0),@Sum7=COALESCE(SUM(SP11906),0),@Sum8=COALESCE(SUM(SP11910),0),
@Sum9=COALESCE(SUM(SP11912),0),@Sum10=COALESCE(SUM(SP11914),0),@Sum11=COALESCE(SUM(SP11916),0) FROM DT11918 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>99999999999.999 SELECT @Sum0=99999999999.999*SIGN(@Sum0)
    IF ABS(@Sum1)>999999999999.99 SELECT @Sum1=999999999999.99*SIGN(@Sum1)
    IF ABS(@Sum2)>999999999999.99 SELECT @Sum2=999999999999.99*SIGN(@Sum2)
    IF ABS(@Sum3)>99999999999.999 SELECT @Sum3=99999999999.999*SIGN(@Sum3)
    IF ABS(@Sum4)>99999999999.999 SELECT @Sum4=99999999999.999*SIGN(@Sum4)
    IF ABS(@Sum5)>99999999999.999 SELECT @Sum5=99999999999.999*SIGN(@Sum5)
    IF ABS(@Sum6)>99999999999.999 SELECT @Sum6=99999999999.999*SIGN(@Sum6)
    IF ABS(@Sum7)>99999999999.999 SELECT @Sum7=99999999999.999*SIGN(@Sum7)
    IF ABS(@Sum8)>99999999999.999 SELECT @Sum8=99999999999.999*SIGN(@Sum8)
    IF ABS(@Sum9)>99999999999.999 SELECT @Sum9=99999999999.999*SIGN(@Sum9)
    IF ABS(@Sum10)>99999999999.999 SELECT @Sum10=99999999999.999*SIGN(@Sum10)
    IF ABS(@Sum11)>99999999999.999 SELECT @Sum11=99999999999.999*SIGN(@Sum11)
UPDATE DH11918 SET SP11884=@Sum0,SP11885=@Sum1,SP11886=@Sum2,SP11899=@Sum3,SP11900=@Sum4,SP11902=@Sum5,SP11905=@Sum6,SP11906=@Sum7,SP11910=@Sum8,SP11912=@Sum9,SP11914=@Sum10,SP11916=@Sum11 WHERE IDDOC=@IdDoc
\}
