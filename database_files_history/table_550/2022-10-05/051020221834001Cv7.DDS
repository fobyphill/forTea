#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH13225_UpdateTotals     |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,2),@Sum1 NUMERIC(28,2),@Sum2 NUMERIC(28,2),@Sum3 NUMERIC(28,2),@Sum4 NUMERIC(28,2),@Sum5 NUMERIC(28,2),@Sum6 NUMERIC(28,2),@Sum7 NUMERIC(28,2),@Sum8 NUMERIC(28,2),@Sum9 NUMERIC(28,2),@Sum10 NUMERIC(28,2),@Sum11 NUMERIC(28,2),@Sum12 NUMERIC(28,2),@Sum13 NUMERIC(28,2),
@Sum14 NUMERIC(28,2),@Sum15 NUMERIC(28,2),@Sum16 NUMERIC(28,2),@Sum17 NUMERIC(28,2),@Sum18 NUMERIC(28,2),@Sum19 NUMERIC(28,2) 
SELECT @Sum0=COALESCE(SUM(SP13204),0),@Sum1=COALESCE(SUM(SP13205),0),@Sum2=COALESCE(SUM(SP13206),0),@Sum3=COALESCE(SUM(SP13207),0),@Sum4=COALESCE(SUM(SP13208),0),@Sum5=COALESCE(SUM(SP13209),0),@Sum6=COALESCE(SUM(SP13210),0),@Sum7=COALESCE(SUM(SP13211),0),@Sum8=COALESCE(SUM(SP13212),0),
@Sum9=COALESCE(SUM(SP13213),0),@Sum10=COALESCE(SUM(SP13214),0),@Sum11=COALESCE(SUM(SP13215),0),@Sum12=COALESCE(SUM(SP13216),0),@Sum13=COALESCE(SUM(SP13217),0),@Sum14=COALESCE(SUM(SP13218),0),@Sum15=COALESCE(SUM(SP13219),0),@Sum16=COALESCE(SUM(SP13220),0),@Sum17=COALESCE(SUM(SP13221),0),
@Sum18=COALESCE(SUM(SP13222),0),@Sum19=COALESCE(SUM(SP13223),0) FROM DT13225 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>999999999999.99 SELECT @Sum0=999999999999.99*SIGN(@Sum0)
    IF ABS(@Sum1)>999999999999.99 SELECT @Sum1=999999999999.99*SIGN(@Sum1)
    IF ABS(@Sum2)>999999999999.99 SELECT @Sum2=999999999999.99*SIGN(@Sum2)
    IF ABS(@Sum3)>999999999999.99 SELECT @Sum3=999999999999.99*SIGN(@Sum3)
    IF ABS(@Sum4)>999999999999.99 SELECT @Sum4=999999999999.99*SIGN(@Sum4)
    IF ABS(@Sum5)>999999999999.99 SELECT @Sum5=999999999999.99*SIGN(@Sum5)
    IF ABS(@Sum6)>999999999999.99 SELECT @Sum6=999999999999.99*SIGN(@Sum6)
    IF ABS(@Sum7)>999999999999.99 SELECT @Sum7=999999999999.99*SIGN(@Sum7)
    IF ABS(@Sum8)>999999999999.99 SELECT @Sum8=999999999999.99*SIGN(@Sum8)
    IF ABS(@Sum9)>999999999999.99 SELECT @Sum9=999999999999.99*SIGN(@Sum9)
    IF ABS(@Sum10)>999999999999.99 SELECT @Sum10=999999999999.99*SIGN(@Sum10)
    IF ABS(@Sum11)>999999999999.99 SELECT @Sum11=999999999999.99*SIGN(@Sum11)
    IF ABS(@Sum12)>999999999999.99 SELECT @Sum12=999999999999.99*SIGN(@Sum12)
    IF ABS(@Sum13)>999999999999.99 SELECT @Sum13=999999999999.99*SIGN(@Sum13)
    IF ABS(@Sum14)>999999999999.99 SELECT @Sum14=999999999999.99*SIGN(@Sum14)
    IF ABS(@Sum15)>999999999999.99 SELECT @Sum15=999999999999.99*SIGN(@Sum15)
    IF ABS(@Sum16)>999999999999.99 SELECT @Sum16=999999999999.99*SIGN(@Sum16)
    IF ABS(@Sum17)>999999999999.99 SELECT @Sum17=999999999999.99*SIGN(@Sum17)
    IF ABS(@Sum18)>999999999999.99 SELECT @Sum18=999999999999.99*SIGN(@Sum18)
    IF ABS(@Sum19)>999999999999.99 SELECT @Sum19=999999999999.99*SIGN(@Sum19)
UPDATE DH13225 SET SP13204=@Sum0,SP13205=@Sum1,SP13206=@Sum2,SP13207=@Sum3,SP13208=@Sum4,SP13209=@Sum5,SP13210=@Sum6,SP13211=@Sum7,SP13212=@Sum8,SP13213=@Sum9,SP13214=@Sum10,SP13215=@Sum11,SP13216=@Sum12,SP13217=@Sum13,SP13218=@Sum14,SP13219=@Sum15,SP13220=@Sum16,SP13221=@Sum17,SP13222=@Sum18,SP13223=@Sum19 WHERE IDDOC=@IdDoc
\}
