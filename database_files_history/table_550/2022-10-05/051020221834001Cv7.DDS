P=_1sp_RA4714_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(9), @p2 CHAR(9), @f0 NUMERIC(14, 3), @f1 NUMERIC(14, 3), @f2 NUMERIC(7, 2), @f3 NUMERIC(4, 2), @f4 NUMERIC(7, 2), @f5 NUMERIC(14, 3), @f6 NUMERIC(14, 3), @f7 NUMERIC(14, 3)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA4714 CURSOR FOR SELECT DEBKRED, SP4711, SP4712, SP4830, SP4713, SP4928, SP4831, SP5685, SP7470, SP11529, SP11530, SP11595  FROM RA4714 WHERE IDDOC=@IdDoc
OPEN Cur_RA4714
FETCH NEXT FROM Cur_RA4714 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4, @f5=-@f5, @f6=-@f6, @f7=-@f7
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG4714_Change @Period, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG4714_Change @CurPeriod, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG4714_Change @Period, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7
    END

    FETCH NEXT FROM Cur_RA4714 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7
END
CLOSE Cur_RA4714
DEALLOCATE Cur_RA4714
\}
