#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA12888_ClearRecalcDocAct|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(9), @p2 CHAR(13), @f0 NUMERIC(14, 2), @f1 NUMERIC(14, 2), @f2 NUMERIC(14, 2), @f3 NUMERIC(14, 2), @f4 NUMERIC(14, 2)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA12888 CURSOR FOR SELECT DEBKRED, SP12946, SP12947, SP12948, SP13071, SP12949, SP12950, SP12951, SP12952  FROM RA12888 WHERE IDDOC=@IdDoc
OPEN Cur_RA12888
FETCH NEXT FROM Cur_RA12888 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG12888_Change @Period, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG12888_Change @CurPeriod, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG12888_Change @Period, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4
    END

    FETCH NEXT FROM Cur_RA12888 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4
END
CLOSE Cur_RA12888
DEALLOCATE Cur_RA12888
\}
