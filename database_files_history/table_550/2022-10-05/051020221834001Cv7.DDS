# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG866                       |PERIOD+PROP   |1     |PERIOD,SP920,SP867,SP868                                    |1          
I=VIA867                         |VIA867        |0     |PERIOD,SP867                                                |0          
I=VIA868                         |VIA868        |0     |PERIOD,SP868                                                |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG866_Change             |              |@per D,@p1 C(13),@p2 C(13),@p3 C(9),@p4 N(14,3),@p5 N(14,4)|{\
Set Nocount On
Update RG866
  set SP869=Case When ABS(SP869+@p4)>99999999999.999 Then 99999999999.999 Else SP869+@p4 End,SP870=Case When ABS(SP870+@p5)>9999999999.9999 Then 9999999999.9999 Else SP870+@p5 End
  where PERIOD=@per AND SP920=@p1 AND SP867=@p2 AND SP868=@p3
if @@ROWCOUNT=0
    insert into RG866 values(@per,@p1,@p2,@p3,@p4,@p5)
\}
