#
#===============================================================================
#==PROCEDURE EscalateTLock
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA6713_TLock             |EscalateTLock |                                        |set nocount on declare @i integer select @i=1 from RA6713(TABLOCK HOLDLOCK) where 0=1
#
#===============================================================================
#==PROCEDURE EscalateTLockX
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA6713_TLockX            |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RA6713(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 679    : Регистр (Дв.) ОВСбСумма
# Name    |Descr                         |SQLTableNam|RecordLock
T=RA6713  |Регистр (Дв.) ОВСбСумма       |RA6713     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=IDDOC                 |ID Document's       |C   |9     |0        
F=LINENO_               |LineNo              |S   |0     |0        
F=ACTNO                 |Action No           |I   |0     |0        
F=DEBKRED               |Flag Debet/Kredit   |L   |0     |0        
F=IDDOCDEF              |ID Def Document     |I   |0     |0        
F=DATE_TIME_IDDOC       |Date+Time+IDDoc     |C   |23    |0        
F=SP6708                |(P)Договор          |C   |13    |0        
F=SP6709                |(P)Партия           |C   |13    |0        
F=SP6710                |(P)Товар            |C   |9     |0        
F=SP6711                |(P)Сумма            |N   |14    |3        
F=SP6712                |(P)Фирма            |C   |9     |0        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA6713                      |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
I=VIA6709                        |VIA6709       |1     |SP6709,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
I=VIA6710                        |VIA6710       |1     |SP6710,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA6713_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @p1 CHAR(13), @p2 CHAR(9), @f0 NUMERIC(14, 3)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA6713 CURSOR FOR SELECT DEBKRED, SP6708, SP6709, SP6710, SP6711  FROM RA6713 WHERE IDDOC=@IdDoc
OPEN Cur_RA6713
FETCH NEXT FROM Cur_RA6713 INTO @DebetCredit, @p0, @p1, @p2, @f0
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG6713_Change @Period, @p0, @p1, @p2, @f0
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG6713_Change @CurPeriod, @p0, @p1, @p2, @f0
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG6713_Change @Period, @p0, @p1, @p2, @f0
    END

    FETCH NEXT FROM Cur_RA6713 INTO @DebetCredit, @p0, @p1, @p2, @f0
END
CLOSE Cur_RA6713
DEALLOCATE Cur_RA6713
\}
