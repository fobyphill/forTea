DECLARE Cur_RA7042 CURSOR FOR SELECT DEBKRED, SP7038, SP7039, SP7040, SP7041, SP7067  FROM RA7042 WHERE IDDOC=@IdDoc
OPEN Cur_RA7042
FETCH NEXT FROM Cur_RA7042 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG7042_Change @Period, @p0, @p1, @p2, @f0, @f1
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG7042_Change @CurPeriod, @p0, @p1, @p2, @f0, @f1
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG7042_Change @Period, @p0, @p1, @p2, @f0, @f1
    END

    FETCH NEXT FROM Cur_RA7042 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1
END
CLOSE Cur_RA7042
DEALLOCATE Cur_RA7042
\}
