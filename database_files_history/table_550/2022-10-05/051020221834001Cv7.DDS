#
#===============================================================================
#==TABLE no 760    : Регистр СостояниеДоговоровТК
# Name    |Descr                         |SQLTableNam|RecordLock
T=RG12888 |Регистр СостояниеДоговоровТК  |RG12888    |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP12946               |(P)ДоговорТК        |C   |9     |0        
F=SP12947               |(P)ДокументЗаявки   |C   |9     |0        
F=SP12948               |(P)ДокументДоставки |C   |13    |0        
F=SP13071               |(P)Необработано     |N   |14    |2        
F=SP12949               |(P)СуммаПоТовару    |N   |14    |2        
F=SP12950               |(P)ОжиданиеДенег    |N   |14    |2        
F=SP12951               |(P)ЗаДоставкуВсего  |N   |14    |2        
F=SP12952               |(P)КомиссияНаличные |N   |14    |2        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG12888                     |PERIOD+PROP   |1     |PERIOD,SP12946,SP12947,SP12948                              |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG12888_Change           |              |@per D,@p1 C(9),@p2 C(9),@p3 C(13),@p4 N(14,2),@p5 N(14,2),@p6 N(14,2),@p7 N(14,2),@p8 N(14,2)|{\
Set Nocount On
Update RG12888
  set SP13071=Case When ABS(SP13071+@p4)>999999999999.99 Then 999999999999.99 Else SP13071+@p4 End,SP12949=Case When ABS(SP12949+@p5)>999999999999.99 Then 999999999999.99 Else SP12949+@p5 End,SP12950=Case When ABS(SP12950+@p6)>999999999999.99 Then 999999999999.99 Else SP12950+@p6 End,SP12951=Case When ABS(SP12951+@p7)>999999999999.99 Then 999999999999.99 Else SP12951+@p7 End,SP12952=Case When ABS(SP12952+@p8)>999999999999.99 Then 999999999999.99 Else SP12952+@p8 End
  where PERIOD=@per AND SP12946=@p1 AND SP12947=@p2 AND SP12948=@p3
if @@ROWCOUNT=0
    insert into RG12888 values(@per,@p1,@p2,@p3,@p4,@p5,@p6,@p7,@p8)
\}
