#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA4342_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @p1 CHAR(9), @f0 NUMERIC(14, 4), @f1 NUMERIC(14, 4), @f2 NUMERIC(14, 3)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA4342 CURSOR FOR SELECT DEBKRED, SP4336, SP4337, SP4338, SP4339, SP4340  FROM RA4342 WHERE IDDOC=@IdDoc
OPEN Cur_RA4342
FETCH NEXT FROM Cur_RA4342 INTO @DebetCredit, @p0, @p1, @f0, @f1, @f2
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG4342_Change @Period, @p0, @p1, @f0, @f1, @f2
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG4342_Change @CurPeriod, @p0, @p1, @f0, @f1, @f2
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG4342_Change @Period, @p0, @p1, @f0, @f1, @f2
    END

    FETCH NEXT FROM Cur_RA4342 INTO @DebetCredit, @p0, @p1, @f0, @f1, @f2
END
CLOSE Cur_RA4342
DEALLOCATE Cur_RA4342
\}
