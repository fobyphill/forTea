P=_1sp_DH7506_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4) 
SELECT @Sum0=COALESCE(SUM(SP7499),0) FROM DT7506 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
UPDATE DH7506 SET SP7499=@Sum0 WHERE IDDOC=@IdDoc
\}
