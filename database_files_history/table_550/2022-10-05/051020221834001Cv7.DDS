#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA12439_ClearRecalcDocAct|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @p1 CHAR(13), @p2 CHAR(9), @p3 CHAR(9), @p4 CHAR(9), @p5 CHAR(13), @f0 NUMERIC(14, 4), @f1 NUMERIC(14, 4), @f2 NUMERIC(14, 4), @f3 NUMERIC(14, 4), @f4 NUMERIC(14, 4), @f5 NUMERIC(14, 4)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA12439 CURSOR FOR SELECT DEBKRED, SP12433, SP12953, SP12818, SP12817, SP12816, SP12833, SP12434, SP12834, SP12835, SP12437, SP12438, SP13129  FROM RA12439 WHERE IDDOC=@IdDoc
OPEN Cur_RA12439
FETCH NEXT FROM Cur_RA12439 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @p5, @f0, @f1, @f2, @f3, @f4, @f5
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4, @f5=-@f5
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG12439_Change @Period, @p0, @p1, @p2, @p3, @p4, @p5, @f0, @f1, @f2, @f3, @f4, @f5
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG12439_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @p5, @f0, @f1, @f2, @f3, @f4, @f5
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG12439_Change @Period, @p0, @p1, @p2, @p3, @p4, @p5, @f0, @f1, @f2, @f3, @f4, @f5
    END

    FETCH NEXT FROM Cur_RA12439 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @p5, @f0, @f1, @f2, @f3, @f4, @f5
END
CLOSE Cur_RA12439
DEALLOCATE Cur_RA12439
\}
