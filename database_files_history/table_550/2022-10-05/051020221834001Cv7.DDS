I=PK_RA12432                     |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA12432_ClearRecalcDocAct|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @f0 NUMERIC(1, 0)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA12432 CURSOR FOR SELECT DEBKRED, SP12430, SP12431  FROM RA12432 WHERE IDDOC=@IdDoc
OPEN Cur_RA12432
FETCH NEXT FROM Cur_RA12432 INTO @DebetCredit, @p0, @f0
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG12432_Change @Period, @p0, @f0
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG12432_Change @CurPeriod, @p0, @f0
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG12432_Change @Period, @p0, @f0
    END

    FETCH NEXT FROM Cur_RA12432 INTO @DebetCredit, @p0, @f0
END
CLOSE Cur_RA12432
DEALLOCATE Cur_RA12432
\}
