DECLARE Cur_RA908 CURSOR FOR SELECT DEBKRED, SP910, SP925, SP912, SP2582, SP913, SP1854, SP911  FROM RA908 WHERE IDDOC=@IdDoc
OPEN Cur_RA908
FETCH NEXT FROM Cur_RA908 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @p5, @f0
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG908_Change @Period, @p0, @p1, @p2, @p3, @p4, @p5, @f0
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG908_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @p5, @f0
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG908_Change @Period, @p0, @p1, @p2, @p3, @p4, @p5, @f0
    END

    FETCH NEXT FROM Cur_RA908 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @p5, @f0
END
CLOSE Cur_RA908
DEALLOCATE Cur_RA908
\}
