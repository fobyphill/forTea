#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA9491_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @p1 CHAR(9), @p2 CHAR(9), @p3 CHAR(9), @f0 NUMERIC(14, 2), @f1 NUMERIC(14, 3)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA9491 CURSOR FOR SELECT DEBKRED, SP11800, SP11801, SP9492, SP10396, SP9493, SP11802  FROM RA9491 WHERE IDDOC=@IdDoc
OPEN Cur_RA9491
FETCH NEXT FROM Cur_RA9491 INTO @DebetCredit, @p0, @p1, @p2, @p3, @f0, @f1
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG9491_Change @Period, @p0, @p1, @p2, @p3, @f0, @f1
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG9491_Change @CurPeriod, @p0, @p1, @p2, @p3, @f0, @f1
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG9491_Change @Period, @p0, @p1, @p2, @p3, @f0, @f1
    END

    FETCH NEXT FROM Cur_RA9491 INTO @DebetCredit, @p0, @p1, @p2, @p3, @f0, @f1
END
CLOSE Cur_RA9491
DEALLOCATE Cur_RA9491
\}
