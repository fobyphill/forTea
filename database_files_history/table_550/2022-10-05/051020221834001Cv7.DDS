#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA5865_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(9), @p2 CHAR(9), @p3 CHAR(100), @p4 CHAR(50), @f0 NUMERIC(9, 3), @f1 NUMERIC(9, 3)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA5865 CURSOR FOR SELECT DEBKRED, SP5858, SP5859, SP5860, SP5861, SP5862, SP5863, SP5864  FROM RA5865 WHERE IDDOC=@IdDoc
OPEN Cur_RA5865
FETCH NEXT FROM Cur_RA5865 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @f0, @f1
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG5865_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0, @f1
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG5865_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @f0, @f1
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG5865_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0, @f1
    END

    FETCH NEXT FROM Cur_RA5865 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @f0, @f1
END
CLOSE Cur_RA5865
DEALLOCATE Cur_RA5865
\}
#
