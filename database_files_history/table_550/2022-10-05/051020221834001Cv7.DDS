# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH14702_UpdateTotals     |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4),@Sum1 NUMERIC(28,2),@Sum2 NUMERIC(28,4) 
SELECT @Sum0=COALESCE(SUM(SP14695),0),@Sum1=COALESCE(SUM(SP14697),0),@Sum2=COALESCE(SUM(SP14698),0) FROM DT14702 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
    IF ABS(@Sum1)>999999999999.99 SELECT @Sum1=999999999999.99*SIGN(@Sum1)
    IF ABS(@Sum2)>9999999999.9999 SELECT @Sum2=9999999999.9999*SIGN(@Sum2)
UPDATE DH14702 SET SP14695=@Sum0,SP14697=@Sum1,SP14698=@Sum2 WHERE IDDOC=@IdDoc
\}
