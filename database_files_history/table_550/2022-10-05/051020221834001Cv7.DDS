P=_1sp_RA5865_WriteDocAct       |              |@IdDoc C(9), @LineNo S, @ActNo I, @DebetCredit L, @IdDocDef I, @DateTimeIdDoc C(23), @p0 C(9), @p1 C(9), @p2 C(9), @p3 C(100), @p4 C(50), @f0 N(9,3), @f1 N(9,3), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM

EXECUTE _1sp_GetBeginOfPeriod @PeriodTA, @SnapShotPeriod, @PeriodTA OUTPUT
INSERT INTO RA5865 VALUES(@IdDoc, @LineNo, @ActNo, @DebetCredit,@IdDocDef,@DateTimeIdDoc, @p0, @p1, @p2, @p3, @p4, @f0, @f1)
IF @DebetCredit=1
    SELECT @f0=-@f0, @f1=-@f1
IF @RepeatToTM=1 BEGIN
    SELECT @Period=@CurPeriod
    WHILE @Period<=@PeriodTA BEGIN
        EXECUTE _1sp_RG5865_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0, @f1
        EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
    END
END
ELSE
    EXECUTE _1sp_RG5865_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @f0, @f1
IF @SaveTurnsWithMonth=1 BEGIN
    EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
    EXECUTE _1sp_RG5865_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0, @f1
END
\}
