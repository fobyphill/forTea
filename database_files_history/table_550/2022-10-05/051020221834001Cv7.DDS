P=_1sp_RA895_WriteDocAct        |              |@IdDoc C(9), @LineNo S, @ActNo I, @DebetCredit L, @IdDocDef I, @DateTimeIdDoc C(23), @p0 C(13), @p1 C(9), @p2 C(9), @p3 D, @p4 C(9), @f0 N(14,3), @f1 N(14,3), @f2 N(14,4), @f3 N(14,4), @f4 N(18,9), @f5 N(18,9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM

EXECUTE _1sp_GetBeginOfPeriod @PeriodTA, @SnapShotPeriod, @PeriodTA OUTPUT
INSERT INTO RA895 VALUES(@IdDoc, @LineNo, @ActNo, @DebetCredit,@IdDocDef,@DateTimeIdDoc, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2, @f3, @f4, @f5)
IF @DebetCredit=1
    SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4, @f5=-@f5
IF @RepeatToTM=1 BEGIN
    SELECT @Period=@CurPeriod
    WHILE @Period<=@PeriodTA BEGIN
        EXECUTE _1sp_RG895_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2, @f3, @f4, @f5
        EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
    END
END
ELSE
    EXECUTE _1sp_RG895_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2, @f3, @f4, @f5
IF @SaveTurnsWithMonth=1 BEGIN
    EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
    EXECUTE _1sp_RG895_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2, @f3, @f4, @f5
END
\}
