#
#===============================================================================
#==PROCEDURE EscalateTLock
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG8050_TLock             |EscalateTLock |                                        |set nocount on declare @i integer select @i=1 from RG8050(TABLOCK HOLDLOCK) where 0=1
#
#===============================================================================
#==PROCEDURE EscalateTLockX
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG8050_TLockX            |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RG8050(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 710    : Регистр Кредит
# Name    |Descr                         |SQLTableNam|RecordLock
T=RG8050  |Регистр Кредит                |RG8050     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP8046                |(P)Договор          |C   |9     |0        
F=SP8047                |(P)ДатаПогашения    |D   |0     |0        
F=SP8048                |(P)Сумма            |N   |14    |2        
F=SP8049                |(P)СуммаПроцентов   |N   |14    |2        
F=SP8126                |(P)СуммаНевыбор     |N   |14    |2        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG8050                      |PERIOD+PROP   |1     |PERIOD,SP8046,SP8047                                        |1          
I=VIA8047                        |VIA8047       |0     |PERIOD,SP8047                                               |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG8050_Change            |              |@per D,@p1 C(9),@p2 D,@p3 N(14,2),@p4 N(14,2),@p5 N(14,2)|{\
Set Nocount On
Update RG8050
  set SP8048=Case When ABS(SP8048+@p3)>999999999999.99 Then 999999999999.99 Else SP8048+@p3 End,SP8049=Case When ABS(SP8049+@p4)>999999999999.99 Then 999999999999.99 Else SP8049+@p4 End,SP8126=Case When ABS(SP8126+@p5)>999999999999.99 Then 999999999999.99 Else SP8126+@p5 End
  where PERIOD=@per AND SP8046=@p1 AND SP8047=@p2
if @@ROWCOUNT=0
    insert into RG8050 values(@per,@p1,@p2,@p3,@p4,@p5)
\}
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG8050_Select            |              |@per D,@p1 C(9),@p2 D,@p3 N(14,2) O,@p4 N(14,2) O,@p5 N(14,2) O|Select @p3=SP8048,@p4=SP8049,@p5=SP8126 from RG8050 where PERIOD=@per AND SP8046=@p1 AND SP8047=@p2
#
#===============================================================================
#==PROCEDURE EscalateTLock
# Name                          |Descr         |Parameters                              |Source                                                                          
