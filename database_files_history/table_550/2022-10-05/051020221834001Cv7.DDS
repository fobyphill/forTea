#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH5347_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,5),@Sum1 NUMERIC(28,5) 
SELECT @Sum0=COALESCE(SUM(SP5342),0),@Sum1=COALESCE(SUM(SP5343),0) FROM DT5347 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>999999999.99999 SELECT @Sum0=999999999.99999*SIGN(@Sum0)
    IF ABS(@Sum1)>999999999.99999 SELECT @Sum1=999999999.99999*SIGN(@Sum1)
UPDATE DH5347 SET SP5342=@Sum0,SP5343=@Sum1 WHERE IDDOC=@IdDoc
\}
#
