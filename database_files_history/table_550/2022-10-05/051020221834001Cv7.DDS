P=_1sp_RA9506_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(9), @p2 CHAR(9), @f0 NUMERIC(9, 3)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA9506 CURSOR FOR SELECT DEBKRED, SP9507, SP10737, SP11295, SP9508  FROM RA9506 WHERE IDDOC=@IdDoc
OPEN Cur_RA9506
FETCH NEXT FROM Cur_RA9506 INTO @DebetCredit, @p0, @p1, @p2, @f0
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG9506_Change @Period, @p0, @p1, @p2, @f0
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG9506_Change @CurPeriod, @p0, @p1, @p2, @f0
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG9506_Change @Period, @p0, @p1, @p2, @f0
    END

    FETCH NEXT FROM Cur_RA9506 INTO @DebetCredit, @p0, @p1, @p2, @f0
END
CLOSE Cur_RA9506
DEALLOCATE Cur_RA9506
\}
