#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA5130_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(13), @f0 NUMERIC(14, 4), @f1 NUMERIC(14, 4), @f2 NUMERIC(14, 4), @f3 NUMERIC(14, 4)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA5130 CURSOR FOR SELECT DEBKRED, SP5119, SP5120, SP5121, SP5122, SP5123, SP5124  FROM RA5130 WHERE IDDOC=@IdDoc
OPEN Cur_RA5130
FETCH NEXT FROM Cur_RA5130 INTO @DebetCredit, @p0, @p1, @f0, @f1, @f2, @f3
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG5130_Change @Period, @p0, @p1, @f0, @f1, @f2, @f3
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG5130_Change @CurPeriod, @p0, @p1, @f0, @f1, @f2, @f3
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG5130_Change @Period, @p0, @p1, @f0, @f1, @f2, @f3
    END

    FETCH NEXT FROM Cur_RA5130 INTO @DebetCredit, @p0, @p1, @f0, @f1, @f2, @f3
END
CLOSE Cur_RA5130
DEALLOCATE Cur_RA5130
\}
