P=_1sp_RG5187_TLock             |EscalateTLock |                                        |set nocount on declare @i integer select @i=1 from RG5187(TABLOCK HOLDLOCK) where 0=1
#
#===============================================================================
#==PROCEDURE EscalateTLockX
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG5187_TLockX            |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RG5187(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 668    : Регистр МягкиеРезервыТоваров
# Name    |Descr                         |SQLTableNam|RecordLock
T=RG5187  |Регистр МягкиеРезервыТоваров  |RG5187     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP5180                |(P)Склад            |C   |9     |0        
F=SP5181                |(P)Документ         |C   |13    |0        
F=SP5182                |(P)Товар            |C   |9     |0        
F=SP5183                |(P)ДатаМР           |D   |0     |0        
F=SP5184                |(P)Количество       |N   |14    |3        
F=SP5185                |(P)Сумма            |N   |14    |4        
F=SP5186                |(P)НДС              |N   |14    |4        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG5187                      |PERIOD+PROP   |1     |PERIOD,SP5180,SP5181,SP5182,SP5183                          |1          
I=VIA5181                        |VIA5181       |0     |PERIOD,SP5181                                               |0          
I=VIA5182                        |VIA5182       |0     |PERIOD,SP5182                                               |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG5187_Change            |              |@per D,@p1 C(9),@p2 C(13),@p3 C(9),@p4 D,@p5 N(14,3),@p6 N(14,4),@p7 N(14,4)|{\
Set Nocount On
Update RG5187
  set SP5184=Case When ABS(SP5184+@p5)>99999999999.999 Then 99999999999.999 Else SP5184+@p5 End,SP5185=Case When ABS(SP5185+@p6)>9999999999.9999 Then 9999999999.9999 Else SP5185+@p6 End,SP5186=Case When ABS(SP5186+@p7)>9999999999.9999 Then 9999999999.9999 Else SP5186+@p7 End
  where PERIOD=@per AND SP5180=@p1 AND SP5181=@p2 AND SP5182=@p3 AND SP5183=@p4
if @@ROWCOUNT=0
    insert into RG5187 values(@per,@p1,@p2,@p3,@p4,@p5,@p6,@p7)
\}
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
