#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH12476_UpdateTotals     |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,2) 
SELECT @Sum0=COALESCE(SUM(SP12473),0) FROM DT12476 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>999999999999.99 SELECT @Sum0=999999999999.99*SIGN(@Sum0)
UPDATE DH12476 SET SP12473=@Sum0 WHERE IDDOC=@IdDoc
\}
#
