F=SP2167                |(P)РасчНП           |N   |18    |9        
F=SP6564                |(P)Акция            |C   |9     |0        
F=SP12396               |(P)Снять            |N   |14    |4        
F=SP12397               |(P)СнятьВО          |N   |14    |4        
F=SP12443               |(P)ПриоритетнаяПарти|C   |13    |0        
F=SP12444               |(P)СуммаВВалютеДогов|N   |14    |4        
F=SP12445               |(P)ЦенаВВалютеДогово|N   |14    |4        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_DT1304                      |of IDDOC+LineN|1     |IDDOC,LINENO_                                               |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH1304_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4),@Sum1 NUMERIC(28,4),@Sum2 NUMERIC(28,4),@Sum3 NUMERIC(28,4),@Sum4 NUMERIC(28,4),@Sum5 NUMERIC(28,4) 
SELECT @Sum0=COALESCE(SUM(SP1327),0),@Sum1=COALESCE(SUM(SP1328),0),@Sum2=COALESCE(SUM(SP1329),0),@Sum3=COALESCE(SUM(SP12396),0),@Sum4=COALESCE(SUM(SP12397),0),@Sum5=COALESCE(SUM(SP12444),0) FROM DT1304 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
    IF ABS(@Sum1)>9999999999.9999 SELECT @Sum1=9999999999.9999*SIGN(@Sum1)
    IF ABS(@Sum2)>9999999999.9999 SELECT @Sum2=9999999999.9999*SIGN(@Sum2)
    IF ABS(@Sum3)>9999999999.9999 SELECT @Sum3=9999999999.9999*SIGN(@Sum3)
    IF ABS(@Sum4)>9999999999.9999 SELECT @Sum4=9999999999.9999*SIGN(@Sum4)
    IF ABS(@Sum5)>9999999999.9999 SELECT @Sum5=9999999999.9999*SIGN(@Sum5)
UPDATE DH1304 SET SP1327=@Sum0,SP1328=@Sum1,SP1329=@Sum2,SP12396=@Sum3,SP12397=@Sum4,SP12444=@Sum5 WHERE IDDOC=@IdDoc
\}
