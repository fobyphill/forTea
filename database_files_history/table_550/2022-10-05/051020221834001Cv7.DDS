P=_1sp_RA6713_WriteDocAct       |              |@IdDoc C(9), @LineNo S, @ActNo I, @DebetCredit L, @IdDocDef I, @DateTimeIdDoc C(23), @p0 C(13), @p1 C(13), @p2 C(9), @f0 N(14,3), @g0 C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I|{\
