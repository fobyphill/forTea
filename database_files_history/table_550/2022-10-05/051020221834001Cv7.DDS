P=_1sp_RA908_ClearRecalcDocActs |              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @p1 CHAR(9), @p2 CHAR(9), @p3 NUMERIC(5, 2), @p4 DATETIME, @p5 CHAR(9), @f0 NUMERIC(14, 4)
