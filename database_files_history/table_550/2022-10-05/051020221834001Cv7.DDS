#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA838_ClearRecalcDocActs |              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(13), @p2 CHAR(9), @p3 CHAR(9), @p4 CHAR(9), @p5 CHAR(25), @p6 CHAR(9), @f0 NUMERIC(14, 3), @f1 NUMERIC(14, 3), @f2 NUMERIC(14, 4), @f3 NUMERIC(14, 4), @f4 NUMERIC(14, 4), @f5 NUMERIC(14, 4), @f6 NUMERIC(14, 4), @f7 NUMERIC(14, 4)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA838 CURSOR FOR SELECT DEBKRED, SP839, SP843, SP840, SP2855, SP2856, SP2857, SP2964, SP841, SP905, SP2962, SP2963, SP2968, SP2970, SP2969, SP2972  FROM RA838 WHERE IDDOC=@IdDoc
OPEN Cur_RA838
FETCH NEXT FROM Cur_RA838 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @p5, @p6, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4, @f5=-@f5, @f6=-@f6, @f7=-@f7
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG838_Change @Period, @p0, @p1, @p2, @p3, @p4, @p5, @p6, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG838_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @p5, @p6, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG838_Change @Period, @p0, @p1, @p2, @p3, @p4, @p5, @p6, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7
    END

    FETCH NEXT FROM Cur_RA838 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @p5, @p6, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7
END
CLOSE Cur_RA838
DEALLOCATE Cur_RA838
\}
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA838_WriteDocAct        |              |@IdDoc C(9), @LineNo S, @ActNo I, @DebetCredit L, @IdDocDef I, @DateTimeIdDoc C(23), @p0 C(9), @p1 C(13), @p2 C(9), @p3 C(9), @p4 C(9), @p5 C(25), @p6 C(9), @f0 N(14,3), @f1 N(14,3), @f2 N(14,4), @f3 N(14,4), @f4 N(14,4), @f5 N(14,4), @f6 N(14,4), @f7 N(14,4), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM

EXECUTE _1sp_GetBeginOfPeriod @PeriodTA, @SnapShotPeriod, @PeriodTA OUTPUT
INSERT INTO RA838 VALUES(@IdDoc, @LineNo, @ActNo, @DebetCredit,@IdDocDef,@DateTimeIdDoc, @p0, @p1, @p2, @p3, @p4, @p5, @p6, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7)
IF @DebetCredit=1
    SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4, @f5=-@f5, @f6=-@f6, @f7=-@f7
IF @RepeatToTM=1 BEGIN
    SELECT @Period=@CurPeriod
    WHILE @Period<=@PeriodTA BEGIN
        EXECUTE _1sp_RG838_Change @Period, @p0, @p1, @p2, @p3, @p4, @p5, @p6, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7
        EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
    END
END
ELSE
    EXECUTE _1sp_RG838_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @p5, @p6, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7
IF @SaveTurnsWithMonth=1 BEGIN
    EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
    EXECUTE _1sp_RG838_Change @Period, @p0, @p1, @p2, @p3, @p4, @p5, @p6, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7
END
\}
