IF @DebetCredit=1
    SELECT @f0=-@f0, @f1=-@f1
IF @RepeatToTM=1 BEGIN
    SELECT @Period=@CurPeriod
    WHILE @Period<=@PeriodTA BEGIN
        EXECUTE _1sp_RG13291_Change @Period, @p0, @p1, @p2, @f0, @f1
