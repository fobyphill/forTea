P=_1sp_RA2885_TLockX            |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RA2885(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 613    : Регистр (Дв.) НаименованияКомплектов
# Name    |Descr                         |SQLTableNam|RecordLock
T=RA2885  |Регистр (Дв.) НаименованияКомп|RA2885     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=IDDOC                 |ID Document's       |C   |9     |0        
F=LINENO_               |LineNo              |S   |0     |0        
F=ACTNO                 |Action No           |I   |0     |0        
F=DEBKRED               |Flag Debet/Kredit   |L   |0     |0        
F=SP2905                |(P)Комплект         |C   |9     |0        
F=SP2906                |(P)Комплектация     |C   |13    |0        
F=SP2886                |(P)Товар            |C   |9     |0        
F=SP2888                |(P)ГТД              |C   |30    |0        
F=SP2889                |(P)Страна           |C   |9     |0        
F=SP2890                |(P)Количество       |N   |14    |3        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA2885                      |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA2885_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(13), @p2 CHAR(9), @p3 CHAR(30), @p4 CHAR(9), @f0 NUMERIC(14, 3)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA2885 CURSOR FOR SELECT DEBKRED, SP2905, SP2906, SP2886, SP2888, SP2889, SP2890  FROM RA2885 WHERE IDDOC=@IdDoc
OPEN Cur_RA2885
FETCH NEXT FROM Cur_RA2885 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @f0
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG2885_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG2885_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @f0
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG2885_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0
    END

    FETCH NEXT FROM Cur_RA2885 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @f0
END
CLOSE Cur_RA2885
DEALLOCATE Cur_RA2885
\}
