P=_1sp_RG796_TLock              |EscalateTLock |                                        |set nocount on declare @i integer select @i=1 from RG796(TABLOCK HOLDLOCK) where 0=1
#
#===============================================================================
#==PROCEDURE EscalateTLockX
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG796_TLockX             |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RG796(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 596    : Регистр Банки
# Name    |Descr                         |SQLTableNam|RecordLock
T=RG796   |Регистр Банки                 |RG796      |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP797                 |(P)Фирма            |C   |9     |0        
F=SP1630                |(P)Счет             |C   |9     |0        
F=SP800                 |(P)Сумма            |N   |14    |2        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG796                       |PERIOD+PROP   |1     |PERIOD,SP797,SP1630                                         |1          
I=VIA1630                        |VIA1630       |0     |PERIOD,SP1630                                               |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG796_Change             |              |@per D,@p1 C(9),@p2 C(9),@p3 N(14,2)    |{\
Set Nocount On
Update RG796
  set SP800=Case When ABS(SP800+@p3)>999999999999.99 Then 999999999999.99 Else SP800+@p3 End
  where PERIOD=@per AND SP797=@p1 AND SP1630=@p2
if @@ROWCOUNT=0
    insert into RG796 values(@per,@p1,@p2,@p3)
\}
