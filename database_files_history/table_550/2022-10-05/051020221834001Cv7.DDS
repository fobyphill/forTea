#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH100_UpdateTotals       |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4),@Sum1 NUMERIC(28,2),@Sum2 NUMERIC(28,2) 
SELECT @Sum0=COALESCE(SUM(SP104),0),@Sum1=COALESCE(SUM(SP105),0),@Sum2=COALESCE(SUM(SP106),0) FROM DT100 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
    IF ABS(@Sum1)>999999999999.99 SELECT @Sum1=999999999999.99*SIGN(@Sum1)
    IF ABS(@Sum2)>999999999999.99 SELECT @Sum2=999999999999.99*SIGN(@Sum2)
UPDATE DH100 SET SP104=@Sum0,SP105=@Sum1,SP106=@Sum2 WHERE IDDOC=@IdDoc
\}
