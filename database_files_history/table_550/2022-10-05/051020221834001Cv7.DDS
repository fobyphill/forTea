#
#===============================================================================
#==TABLE no 696    : Регистр ПТОПродажи
# Name    |Descr                         |SQLTableNam|RecordLock
T=RG7052  |Регистр ПТОПродажи            |RG7052     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP7048                |(P)Договор          |C   |13    |0        
F=SP7049                |(P)Партия           |C   |13    |0        
F=SP7050                |(P)Товар            |C   |9     |0        
F=SP7051                |(P)Количество       |N   |14    |3        
F=SP7069                |(P)Сумма            |N   |14    |4        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG7052                      |PERIOD+PROP   |1     |PERIOD,SP7048,SP7049,SP7050                                 |1          
I=VIA7049                        |VIA7049       |0     |PERIOD,SP7049                                               |0          
I=VIA7050                        |VIA7050       |0     |PERIOD,SP7050                                               |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG7052_Change            |              |@per D,@p1 C(13),@p2 C(13),@p3 C(9),@p4 N(14,3),@p5 N(14,4)|{\
Set Nocount On
Update RG7052
  set SP7051=Case When ABS(SP7051+@p4)>99999999999.999 Then 99999999999.999 Else SP7051+@p4 End,SP7069=Case When ABS(SP7069+@p5)>9999999999.9999 Then 9999999999.9999 Else SP7069+@p5 End
  where PERIOD=@per AND SP7048=@p1 AND SP7049=@p2 AND SP7050=@p3
if @@ROWCOUNT=0
    insert into RG7052 values(@per,@p1,@p2,@p3,@p4,@p5)
\}
