#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH10502_UpdateTotals     |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,3),@Sum1 NUMERIC(28,4),@Sum2 NUMERIC(28,4),@Sum3 NUMERIC(28,4),@Sum4 NUMERIC(28,4) 
SELECT @Sum0=COALESCE(SUM(SP10484),0),@Sum1=COALESCE(SUM(SP10486),0),@Sum2=COALESCE(SUM(SP10487),0),@Sum3=COALESCE(SUM(SP10488),0),@Sum4=COALESCE(SUM(SP10489),0) FROM DT10502 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>99999999999.999 SELECT @Sum0=99999999999.999*SIGN(@Sum0)
    IF ABS(@Sum1)>9999999999.9999 SELECT @Sum1=9999999999.9999*SIGN(@Sum1)
    IF ABS(@Sum2)>9999999999.9999 SELECT @Sum2=9999999999.9999*SIGN(@Sum2)
    IF ABS(@Sum3)>9999999999.9999 SELECT @Sum3=9999999999.9999*SIGN(@Sum3)
    IF ABS(@Sum4)>9999999999.9999 SELECT @Sum4=9999999999.9999*SIGN(@Sum4)
UPDATE DH10502 SET SP10484=@Sum0,SP10486=@Sum1,SP10487=@Sum2,SP10488=@Sum3,SP10489=@Sum4 WHERE IDDOC=@IdDoc
\}
#
