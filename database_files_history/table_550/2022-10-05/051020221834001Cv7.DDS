# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH1687_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4),@Sum1 NUMERIC(28,4),@Sum2 NUMERIC(28,4),@Sum3 NUMERIC(28,4),@Sum4 NUMERIC(28,2),@Sum5 NUMERIC(28,2) 
SELECT @Sum0=COALESCE(SUM(SP1707),0),@Sum1=COALESCE(SUM(SP1708),0),@Sum2=COALESCE(SUM(SP1709),0),@Sum3=COALESCE(SUM(SP1710),0),@Sum4=COALESCE(SUM(SP11498),0),@Sum5=COALESCE(SUM(SP3253),0) FROM DT1687 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
    IF ABS(@Sum1)>9999999999.9999 SELECT @Sum1=9999999999.9999*SIGN(@Sum1)
    IF ABS(@Sum2)>9999999999.9999 SELECT @Sum2=9999999999.9999*SIGN(@Sum2)
    IF ABS(@Sum3)>9999999999.9999 SELECT @Sum3=9999999999.9999*SIGN(@Sum3)
    IF ABS(@Sum4)>999999999999.99 SELECT @Sum4=999999999999.99*SIGN(@Sum4)
    IF ABS(@Sum5)>999999999999.99 SELECT @Sum5=999999999999.99*SIGN(@Sum5)
UPDATE DH1687 SET SP1707=@Sum0,SP1708=@Sum1,SP1709=@Sum2,SP1710=@Sum3,SP11498=@Sum4,SP3253=@Sum5 WHERE IDDOC=@IdDoc
\}
