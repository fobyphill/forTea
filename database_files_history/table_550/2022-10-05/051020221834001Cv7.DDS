# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA8050_TLockX            |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RA8050(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 711    : Регистр (Дв.) Кредит
# Name    |Descr                         |SQLTableNam|RecordLock
T=RA8050  |Регистр (Дв.) Кредит          |RA8050     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=IDDOC                 |ID Document's       |C   |9     |0        
F=LINENO_               |LineNo              |S   |0     |0        
F=ACTNO                 |Action No           |I   |0     |0        
F=DEBKRED               |Flag Debet/Kredit   |L   |0     |0        
F=IDDOCDEF              |ID Def Document     |I   |0     |0        
F=DATE_TIME_IDDOC       |Date+Time+IDDoc     |C   |23    |0        
F=SP8046                |(P)Договор          |C   |9     |0        
F=SP8047                |(P)ДатаПогашения    |D   |0     |0        
F=SP8048                |(P)Сумма            |N   |14    |2        
F=SP8049                |(P)СуммаПроцентов   |N   |14    |2        
F=SP8126                |(P)СуммаНевыбор     |N   |14    |2        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA8050                      |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
I=VIA8046                        |VIA8046       |1     |SP8046,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
I=VIA8047                        |VIA8047       |1     |SP8047,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA8050_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 DATETIME, @f0 NUMERIC(14, 2), @f1 NUMERIC(14, 2), @f2 NUMERIC(14, 2)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA8050 CURSOR FOR SELECT DEBKRED, SP8046, SP8047, SP8048, SP8049, SP8126  FROM RA8050 WHERE IDDOC=@IdDoc
OPEN Cur_RA8050
FETCH NEXT FROM Cur_RA8050 INTO @DebetCredit, @p0, @p1, @f0, @f1, @f2
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG8050_Change @Period, @p0, @p1, @f0, @f1, @f2
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG8050_Change @CurPeriod, @p0, @p1, @f0, @f1, @f2
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG8050_Change @Period, @p0, @p1, @f0, @f1, @f2
    END

    FETCH NEXT FROM Cur_RA8050 INTO @DebetCredit, @p0, @p1, @f0, @f1, @f2
END
CLOSE Cur_RA8050
DEALLOCATE Cur_RA8050
\}
