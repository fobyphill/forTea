#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA7852_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @p1 CHAR(9), @p2 CHAR(9), @p3 CHAR(9), @f0 NUMERIC(14, 4), @f1 NUMERIC(14, 4), @f2 NUMERIC(14, 4), @f3 NUMERIC(14, 2), @f4 NUMERIC(14, 4), @f5 NUMERIC(10, 0), @f6 NUMERIC(14, 2), @f7 NUMERIC(14, 2), @f8 NUMERIC(14, 2), @f9 NUMERIC(14, 2), @f10 NUMERIC(14, 3), @f11 NUMERIC(14, 2), @f12 NUMERIC(14, 2), @f13 NUMERIC(14, 2)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA7852 CURSOR FOR SELECT DEBKRED, SP7838, SP7839, SP7840, SP7841, SP7842, SP7843, SP7844, SP7845, SP7846, SP7848, SP7950, SP7951, SP7952, SP7953, SP7960, SP7974, SP7975, SP7976  FROM RA7852 WHERE IDDOC=@IdDoc
OPEN Cur_RA7852
FETCH NEXT FROM Cur_RA7852 INTO @DebetCredit, @p0, @p1, @p2, @p3, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10, @f11, @f12, @f13
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4, @f5=-@f5, @f6=-@f6, @f7=-@f7, @f8=-@f8, @f9=-@f9, @f10=-@f10, @f11=-@f11, @f12=-@f12, @f13=-@f13
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG7852_Change @Period, @p0, @p1, @p2, @p3, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10, @f11, @f12, @f13
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG7852_Change @CurPeriod, @p0, @p1, @p2, @p3, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10, @f11, @f12, @f13
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG7852_Change @Period, @p0, @p1, @p2, @p3, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10, @f11, @f12, @f13
    END

    FETCH NEXT FROM Cur_RA7852 INTO @DebetCredit, @p0, @p1, @p2, @p3, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10, @f11, @f12, @f13
END
CLOSE Cur_RA7852
DEALLOCATE Cur_RA7852
\}
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA7852_WriteDocAct       |              |@IdDoc C(9), @LineNo S, @ActNo I, @DebetCredit L, @IdDocDef I, @DateTimeIdDoc C(23), @p0 C(13), @p1 C(9), @p2 C(9), @p3 C(9), @f0 N(14,4), @f1 N(14,4), @f2 N(14,4), @f3 N(14,2), @f4 N(14,4), @f5 N(10), @f6 N(14,2), @f7 N(14,2), @f8 N(14,2), @f9 N(14,2), @f10 N(14,3), @f11 N(14,2), @f12 N(14,2), @f13 N(14,2), @g0 D, @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM

EXECUTE _1sp_GetBeginOfPeriod @PeriodTA, @SnapShotPeriod, @PeriodTA OUTPUT
INSERT INTO RA7852 VALUES(@IdDoc, @LineNo, @ActNo, @DebetCredit,@IdDocDef,@DateTimeIdDoc, @p0, @p1, @p2, @p3, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10, @f11, @f12, @f13, @g0)
IF @DebetCredit=1
    SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4, @f5=-@f5, @f6=-@f6, @f7=-@f7, @f8=-@f8, @f9=-@f9, @f10=-@f10, @f11=-@f11, @f12=-@f12, @f13=-@f13
IF @RepeatToTM=1 BEGIN
    SELECT @Period=@CurPeriod
    WHILE @Period<=@PeriodTA BEGIN
        EXECUTE _1sp_RG7852_Change @Period, @p0, @p1, @p2, @p3, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10, @f11, @f12, @f13
        EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
    END
END
ELSE
    EXECUTE _1sp_RG7852_Change @CurPeriod, @p0, @p1, @p2, @p3, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10, @f11, @f12, @f13
IF @SaveTurnsWithMonth=1 BEGIN
    EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
    EXECUTE _1sp_RG7852_Change @Period, @p0, @p1, @p2, @p3, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10, @f11, @f12, @f13
END
\}
