#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA895_ClearRecalcDocActs |              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @p1 CHAR(9), @p2 CHAR(9), @p3 DATETIME, @p4 CHAR(9), @f0 NUMERIC(14, 3), @f1 NUMERIC(14, 3), @f2 NUMERIC(14, 4), @f3 NUMERIC(14, 4), @f4 NUMERIC(18, 9), @f5 NUMERIC(18, 9)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA895 CURSOR FOR SELECT DEBKRED, SP897, SP898, SP3096, SP1640, SP5390, SP901, SP906, SP3097, SP3099, SP3100, SP3101  FROM RA895 WHERE IDDOC=@IdDoc
OPEN Cur_RA895
FETCH NEXT FROM Cur_RA895 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2, @f3, @f4, @f5
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4, @f5=-@f5
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG895_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2, @f3, @f4, @f5
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG895_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2, @f3, @f4, @f5
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG895_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2, @f3, @f4, @f5
    END

    FETCH NEXT FROM Cur_RA895 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2, @f3, @f4, @f5
END
CLOSE Cur_RA895
DEALLOCATE Cur_RA895
\}
#
