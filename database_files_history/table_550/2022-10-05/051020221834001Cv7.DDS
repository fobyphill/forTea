#==TABLE no 736    : Регистр ПереченьУслугНаОУПоДоговору
# Name    |Descr                         |SQLTableNam|RecordLock
T=RG9503  |Регистр ПереченьУслугНаОУПоДог|RG9503     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP9504                |(P)ДоговорНаОбслужив|C   |9     |0        
F=SP10738               |(P)ОбъектУслуги     |C   |9     |0        
F=SP10739               |(P)Услуга           |C   |9     |0        
F=SP9505                |(P)Количество       |N   |9     |3        
F=SP11270               |(P)Периодичность    |N   |2     |0        
F=SP11296               |(P)Цена             |N   |14    |4        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG9503                      |PERIOD+PROP   |1     |PERIOD,SP9504,SP10738,SP10739                               |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG9503_Change            |              |@per D,@p1 C(9),@p2 C(9),@p3 C(9),@p4 N(9,3),@p5 N(2),@p6 N(14,4)|{\
Set Nocount On
Update RG9503
  set SP9505=Case When ABS(SP9505+@p4)>999999.999 Then 999999.999 Else SP9505+@p4 End,SP11270=Case When ABS(SP11270+@p5)>99 Then 99 Else SP11270+@p5 End,SP11296=Case When ABS(SP11296+@p6)>9999999999.9999 Then 9999999999.9999 Else SP11296+@p6 End
  where PERIOD=@per AND SP9504=@p1 AND SP10738=@p2 AND SP10739=@p3
if @@ROWCOUNT=0
    insert into RG9503 values(@per,@p1,@p2,@p3,@p4,@p5,@p6)
\}
