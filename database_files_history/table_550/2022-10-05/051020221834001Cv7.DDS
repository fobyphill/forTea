#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG2867_Change            |              |@per D,@p1 C(9),@p2 N(1)                |{\
Set Nocount On
Update RG2867
  set SP2869=Case When ABS(SP2869+@p2)>9 Then 9 Else SP2869+@p2 End
  where PERIOD=@per AND SP2868=@p1
if @@ROWCOUNT=0
    insert into RG2867 values(@per,@p1,@p2)
\}
