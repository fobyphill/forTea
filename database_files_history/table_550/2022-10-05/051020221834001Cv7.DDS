#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH11759_UpdateTotals     |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4),@Sum1 NUMERIC(28,4),@Sum2 NUMERIC(28,4) 
SELECT @Sum0=COALESCE(SUM(SP11745),0),@Sum1=COALESCE(SUM(SP11748),0),@Sum2=COALESCE(SUM(SP11749),0) FROM DT11759 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
    IF ABS(@Sum1)>9999999999.9999 SELECT @Sum1=9999999999.9999*SIGN(@Sum1)
    IF ABS(@Sum2)>9999999999.9999 SELECT @Sum2=9999999999.9999*SIGN(@Sum2)
UPDATE DH11759 SET SP11745=@Sum0,SP11748=@Sum1,SP11749=@Sum2 WHERE IDDOC=@IdDoc
\}
#
