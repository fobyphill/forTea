            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG12259_Change @CurPeriod, @p0, @p1, @p2, @f0
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG12259_Change @Period, @p0, @p1, @p2, @f0
    END

    FETCH NEXT FROM Cur_RA12259 INTO @DebetCredit, @p0, @p1, @p2, @f0
END
CLOSE Cur_RA12259
DEALLOCATE Cur_RA12259
