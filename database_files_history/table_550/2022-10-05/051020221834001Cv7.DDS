#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH9937_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4),@Sum1 NUMERIC(28,4),@Sum2 NUMERIC(28,2) 
SELECT @Sum0=COALESCE(SUM(SP9917),0),@Sum1=COALESCE(SUM(SP9918),0),@Sum2=COALESCE(SUM(SP9931),0) FROM DT9937 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
    IF ABS(@Sum1)>9999999999.9999 SELECT @Sum1=9999999999.9999*SIGN(@Sum1)
    IF ABS(@Sum2)>999999999999.99 SELECT @Sum2=999999999999.99*SIGN(@Sum2)
UPDATE DH9937 SET SP9917=@Sum0,SP9918=@Sum1,SP9931=@Sum2 WHERE IDDOC=@IdDoc
\}
