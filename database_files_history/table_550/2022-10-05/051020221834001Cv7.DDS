#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH14498_UpdateTotals     |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4),@Sum1 NUMERIC(28,2),@Sum2 NUMERIC(28,3),@Sum3 NUMERIC(28,4),@Sum4 NUMERIC(28,2),@Sum5 NUMERIC(28,3) 
SELECT @Sum0=COALESCE(SUM(SP14482),0),@Sum1=COALESCE(SUM(SP14483),0),@Sum2=COALESCE(SUM(SP14491),0),@Sum3=COALESCE(SUM(SP14493),0),@Sum4=COALESCE(SUM(SP14494),0),@Sum5=COALESCE(SUM(SP14495),0) FROM DT14498 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
    IF ABS(@Sum1)>999999999999.99 SELECT @Sum1=999999999999.99*SIGN(@Sum1)
    IF ABS(@Sum2)>99999999999.999 SELECT @Sum2=99999999999.999*SIGN(@Sum2)
    IF ABS(@Sum3)>9999999999.9999 SELECT @Sum3=9999999999.9999*SIGN(@Sum3)
    IF ABS(@Sum4)>999.99 SELECT @Sum4=999.99*SIGN(@Sum4)
    IF ABS(@Sum5)>99999999999.999 SELECT @Sum5=99999999999.999*SIGN(@Sum5)
UPDATE DH14498 SET SP14482=@Sum0,SP14483=@Sum1,SP14491=@Sum2,SP14493=@Sum3,SP14494=@Sum4,SP14495=@Sum5 WHERE IDDOC=@IdDoc
\}
