DECLARE @Sum0 NUMERIC(28,3),@Sum1 NUMERIC(28,3) 
SELECT @Sum0=COALESCE(SUM(SP12290),0),@Sum1=COALESCE(SUM(SP12320),0) FROM DT12232 WHERE IDDOC=@IdDoc
