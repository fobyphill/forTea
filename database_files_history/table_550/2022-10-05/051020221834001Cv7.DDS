#
#===============================================================================
#==TABLE no 275    : Документ (Мн.ч.) КорректировкаКомплектаИКомплектующих
# Name    |Descr                         |SQLTableNam|RecordLock
T=DT8216  |Документ (Мн.ч.) Корректировка|DT8216     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=IDDOC                 |ID Document's       |C   |9     |0        
F=LINENO_               |LineNo              |S   |0     |0        
F=SP8210                |(P)Товар            |C   |9     |0        
F=SP8211                |(P)Количество       |N   |14    |3        
F=SP8212                |(P)Единица          |C   |9     |0        
F=SP8213                |(P)Коэффициент      |N   |14    |3        
F=SP8214                |(P)КоличествоДобавля|N   |14    |3        
F=SP8563                |(P)КоличествоБыло   |N   |14    |3        
F=SP8564                |(P)КоличествоСтало  |N   |14    |3        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_DT8216                      |of IDDOC+LineN|1     |IDDOC,LINENO_                                               |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH8216_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,3),@Sum1 NUMERIC(28,3) 
SELECT @Sum0=COALESCE(SUM(SP8211),0),@Sum1=COALESCE(SUM(SP8214),0) FROM DT8216 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>99999999999.999 SELECT @Sum0=99999999999.999*SIGN(@Sum0)
    IF ABS(@Sum1)>99999999999.999 SELECT @Sum1=99999999999.999*SIGN(@Sum1)
UPDATE DH8216 SET SP8211=@Sum0,SP8214=@Sum1 WHERE IDDOC=@IdDoc
\}
