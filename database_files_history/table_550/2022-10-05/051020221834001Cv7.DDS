    ELSE
        EXECUTE _1sp_RG9500_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @p5, @f0, @f1, @f2, @f3, @f4, @f5, @f6
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG9500_Change @Period, @p0, @p1, @p2, @p3, @p4, @p5, @f0, @f1, @f2, @f3, @f4, @f5, @f6
