I=PK_RG1580                      |PERIOD+PROP   |1     |PERIOD,SP1581,SP1582,SP2768,SP3084,SP3085,SP3758            |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG1580_Change            |              |@per D,@p1 C(9),@p2 C(9),@p3 C(9),@p4 C(9),@p5 C(9),@p6 C(9),@p7 N(14,4)|{\
Set Nocount On
Update RG1580
  set SP1584=Case When ABS(SP1584+@p7)>9999999999.9999 Then 9999999999.9999 Else SP1584+@p7 End
  where PERIOD=@per AND SP1581=@p1 AND SP1582=@p2 AND SP2768=@p3 AND SP3084=@p4 AND SP3085=@p5 AND SP3758=@p6
if @@ROWCOUNT=0
    insert into RG1580 values(@per,@p1,@p2,@p3,@p4,@p5,@p6,@p7)
\}
