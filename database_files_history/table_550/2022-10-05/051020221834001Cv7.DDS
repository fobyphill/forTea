P=_1sp_RG13148_Change           |              |@per D,@p1 C(9),@p2 C(9),@p3 C(9),@p4 C(9),@p5 N(14,2),@p6 N(14,2)|{\
Set Nocount On
Update RG13148
  set SP13151=Case When ABS(SP13151+@p5)>999999999999.99 Then 999999999999.99 Else SP13151+@p5 End,SP13152=Case When ABS(SP13152+@p6)>999999999999.99 Then 999999999999.99 Else SP13152+@p6 End
  where PERIOD=@per AND SP13149=@p1 AND SP13150=@p2 AND SP13156=@p3 AND SP13157=@p4
if @@ROWCOUNT=0
    insert into RG13148 values(@per,@p1,@p2,@p3,@p4,@p5,@p6)
\}
