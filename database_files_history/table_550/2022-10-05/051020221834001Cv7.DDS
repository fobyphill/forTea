P=_1sp_RA8226_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @p1 CHAR(13), @f0 NUMERIC(14, 3), @f1 NUMERIC(14, 3), @f2 NUMERIC(14, 3), @f3 NUMERIC(14, 3), @f4 NUMERIC(14, 3), @f5 NUMERIC(14, 3), @f6 NUMERIC(14, 3), @f7 NUMERIC(14, 2), @f8 NUMERIC(14, 2), @f9 NUMERIC(14, 3)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA8226 CURSOR FOR SELECT DEBKRED, SP8218, SP8446, SP8219, SP8220, SP8221, SP8222, SP8223, SP8224, SP8225, SP8781, SP9006, SP10317  FROM RA8226 WHERE IDDOC=@IdDoc
OPEN Cur_RA8226
FETCH NEXT FROM Cur_RA8226 INTO @DebetCredit, @p0, @p1, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4, @f5=-@f5, @f6=-@f6, @f7=-@f7, @f8=-@f8, @f9=-@f9
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG8226_Change @Period, @p0, @p1, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG8226_Change @CurPeriod, @p0, @p1, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG8226_Change @Period, @p0, @p1, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9
    END

    FETCH NEXT FROM Cur_RA8226 INTO @DebetCredit, @p0, @p1, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9
END
CLOSE Cur_RA8226
DEALLOCATE Cur_RA8226
\}
