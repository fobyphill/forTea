  set SP8649=Case When ABS(SP8649+@p2)>9999999999.9999 Then 9999999999.9999 Else SP8649+@p2 End,SP8650=Case When ABS(SP8650+@p3)>9999999999.9999 Then 9999999999.9999 Else SP8650+@p3 End,SP8651=Case When ABS(SP8651+@p4)>9999999999.9999 Then 9999999999.9999 Else SP8651+@p4 End,SP8652=Case When ABS(SP8652+@p5)>999999999999.99 Then 999999999999.99 Else SP8652+@p5 End,SP8653=Case When ABS(SP8653+@p6)>999999999999.99 Then 999999999999.99 Else SP8653+@p6 End,SP8654=Case When ABS(SP8654+@p7)>999999999999.99 Then 999999999999.99 Else SP8654+@p7 End,SP8655=Case When ABS(SP8655+@p8)>999999999999.99 Then 999999999999.99 Else SP8655+@p8 End,SP8656=Case When ABS(SP8656+@p9)>99999999999.999 Then 99999999999.999 Else SP8656+@p9 End,SP8657=Case When ABS(SP8657+@p10)>999999999999.99 Then 999999999999.99 Else SP8657+@p10 End,SP8658=Case When ABS(SP8658+@p11)>999999999999.99 Then 999999999999.99 Else SP8658+@p11 End,SP8659=Case When ABS(SP8659+@p12)>999999999999.99 Then 999999999999.99 Else SP8659+@p12 End
