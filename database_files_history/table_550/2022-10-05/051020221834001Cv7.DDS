F=SP3608                |(P)КоличествоНаш    |N   |14    |3        
F=SP3609                |(P)НаРемонтеНаш     |N   |10    |0        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA2691                      |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
I=DATETIME                       |Date+Time+IDOC|1     |DATE_TIME_IDDOC,LINENO_,ACTNO                               |0          
I=VIA3412                        |VIA3412       |1     |SP3412,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA2691_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(9), @p2 CHAR(9), @p3 CHAR(13), @f0 NUMERIC(14, 3), @f1 NUMERIC(14, 3), @f2 NUMERIC(14, 3), @f3 NUMERIC(10, 0)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA2691 CURSOR FOR SELECT DEBKRED, SP2692, SP2693, SP2714, SP3412, SP2694, SP3600, SP3608, SP3609  FROM RA2691 WHERE IDDOC=@IdDoc
OPEN Cur_RA2691
FETCH NEXT FROM Cur_RA2691 INTO @DebetCredit, @p0, @p1, @p2, @p3, @f0, @f1, @f2, @f3
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG2691_Change @Period, @p0, @p1, @p2, @p3, @f0, @f1, @f2, @f3
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG2691_Change @CurPeriod, @p0, @p1, @p2, @p3, @f0, @f1, @f2, @f3
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG2691_Change @Period, @p0, @p1, @p2, @p3, @f0, @f1, @f2, @f3
    END

    FETCH NEXT FROM Cur_RA2691 INTO @DebetCredit, @p0, @p1, @p2, @p3, @f0, @f1, @f2, @f3
END
CLOSE Cur_RA2691
DEALLOCATE Cur_RA2691
\}
