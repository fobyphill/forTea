P=_1sp_RA8660_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @f0 NUMERIC(14, 4), @f1 NUMERIC(14, 4), @f2 NUMERIC(14, 4), @f3 NUMERIC(14, 2), @f4 NUMERIC(14, 2), @f5 NUMERIC(14, 2), @f6 NUMERIC(14, 2), @f7 NUMERIC(14, 3), @f8 NUMERIC(14, 2), @f9 NUMERIC(14, 2), @f10 NUMERIC(14, 2)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA8660 CURSOR FOR SELECT DEBKRED, SP8648, SP8649, SP8650, SP8651, SP8652, SP8653, SP8654, SP8655, SP8656, SP8657, SP8658, SP8659  FROM RA8660 WHERE IDDOC=@IdDoc
OPEN Cur_RA8660
FETCH NEXT FROM Cur_RA8660 INTO @DebetCredit, @p0, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4, @f5=-@f5, @f6=-@f6, @f7=-@f7, @f8=-@f8, @f9=-@f9, @f10=-@f10
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG8660_Change @Period, @p0, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG8660_Change @CurPeriod, @p0, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG8660_Change @Period, @p0, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10
    END

    FETCH NEXT FROM Cur_RA8660 INTO @DebetCredit, @p0, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10
END
CLOSE Cur_RA8660
DEALLOCATE Cur_RA8660
\}
