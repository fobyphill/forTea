    EXECUTE _1sp_RG914_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @p5, @f0
IF @SaveTurnsWithMonth=1 BEGIN
    EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
    EXECUTE _1sp_RG914_Change @Period, @p0, @p1, @p2, @p3, @p4, @p5, @f0
END
\}
