I=VIA7610                        |VIA7610       |1     |SP7610,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA7618_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @p1 CHAR(13), @p2 CHAR(9), @f0 NUMERIC(14, 3), @f1 NUMERIC(14, 3), @f2 NUMERIC(14, 4), @f3 NUMERIC(14, 4), @f4 NUMERIC(14, 4), @f5 NUMERIC(14, 4)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA7618 CURSOR FOR SELECT DEBKRED, SP7607, SP7608, SP7610, SP7612, SP7613, SP7614, SP7615, SP7616, SP7617  FROM RA7618 WHERE IDDOC=@IdDoc
OPEN Cur_RA7618
FETCH NEXT FROM Cur_RA7618 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4, @f5
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4, @f5=-@f5
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG7618_Change @Period, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4, @f5
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG7618_Change @CurPeriod, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4, @f5
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG7618_Change @Period, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4, @f5
    END

    FETCH NEXT FROM Cur_RA7618 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4, @f5
END
CLOSE Cur_RA7618
DEALLOCATE Cur_RA7618
\}
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA7618_WriteDocAct       |              |@IdDoc C(9), @LineNo S, @ActNo I, @DebetCredit L, @IdDocDef I, @DateTimeIdDoc C(23), @p0 C(13), @p1 C(13), @p2 C(9), @f0 N(14,3), @f1 N(14,3), @f2 N(14,4), @f3 N(14,4), @f4 N(14,4), @f5 N(14,4), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM

EXECUTE _1sp_GetBeginOfPeriod @PeriodTA, @SnapShotPeriod, @PeriodTA OUTPUT
INSERT INTO RA7618 VALUES(@IdDoc, @LineNo, @ActNo, @DebetCredit,@IdDocDef,@DateTimeIdDoc, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4, @f5)
IF @DebetCredit=1
    SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4, @f5=-@f5
IF @RepeatToTM=1 BEGIN
    SELECT @Period=@CurPeriod
    WHILE @Period<=@PeriodTA BEGIN
        EXECUTE _1sp_RG7618_Change @Period, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4, @f5
        EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
    END
END
ELSE
    EXECUTE _1sp_RG7618_Change @CurPeriod, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4, @f5
IF @SaveTurnsWithMonth=1 BEGIN
    EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
    EXECUTE _1sp_RG7618_Change @Period, @p0, @p1, @p2, @f0, @f1, @f2, @f3, @f4, @f5
END
\}
