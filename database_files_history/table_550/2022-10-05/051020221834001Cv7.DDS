#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA866_ClearRecalcDocActs |              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @p1 CHAR(13), @p2 CHAR(9), @f0 NUMERIC(14, 3), @f1 NUMERIC(14, 4)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA866 CURSOR FOR SELECT DEBKRED, SP920, SP867, SP868, SP869, SP870  FROM RA866 WHERE IDDOC=@IdDoc
OPEN Cur_RA866
FETCH NEXT FROM Cur_RA866 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG866_Change @Period, @p0, @p1, @p2, @f0, @f1
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG866_Change @CurPeriod, @p0, @p1, @p2, @f0, @f1
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG866_Change @Period, @p0, @p1, @p2, @f0, @f1
    END

    FETCH NEXT FROM Cur_RA866 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1
END
CLOSE Cur_RA866
DEALLOCATE Cur_RA866
\}
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA866_WriteDocAct        |              |@IdDoc C(9), @LineNo S, @ActNo I, @DebetCredit L, @IdDocDef I, @DateTimeIdDoc C(23), @p0 C(13), @p1 C(13), @p2 C(9), @f0 N(14,3), @f1 N(14,4), @g0 N(14,4), @g1 N(14,4), @g2 N(18,6), @g3 N(2), @g4 N(18,6), @g5 N(18,6), @g6 C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM

EXECUTE _1sp_GetBeginOfPeriod @PeriodTA, @SnapShotPeriod, @PeriodTA OUTPUT
INSERT INTO RA866 VALUES(@IdDoc, @LineNo, @ActNo, @DebetCredit,@IdDocDef,@DateTimeIdDoc, @p0, @p1, @p2, @f0, @f1, @g0, @g1, @g2, @g3, @g4, @g5, @g6)
IF @DebetCredit=1
    SELECT @f0=-@f0, @f1=-@f1
IF @RepeatToTM=1 BEGIN
    SELECT @Period=@CurPeriod
    WHILE @Period<=@PeriodTA BEGIN
        EXECUTE _1sp_RG866_Change @Period, @p0, @p1, @p2, @f0, @f1
        EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
    END
END
ELSE
    EXECUTE _1sp_RG866_Change @CurPeriod, @p0, @p1, @p2, @f0, @f1
IF @SaveTurnsWithMonth=1 BEGIN
    EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
    EXECUTE _1sp_RG866_Change @Period, @p0, @p1, @p2, @f0, @f1
END
\}
