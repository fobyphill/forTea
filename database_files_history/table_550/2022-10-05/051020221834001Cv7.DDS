#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA8660_WriteDocAct       |              |@IdDoc C(9), @LineNo S, @ActNo I, @DebetCredit L, @IdDocDef I, @DateTimeIdDoc C(23), @p0 C(9), @f0 N(14,4), @f1 N(14,4), @f2 N(14,4), @f3 N(14,2), @f4 N(14,2), @f5 N(14,2), @f6 N(14,2), @f7 N(14,3), @f8 N(14,2), @f9 N(14,2), @f10 N(14,2), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM

EXECUTE _1sp_GetBeginOfPeriod @PeriodTA, @SnapShotPeriod, @PeriodTA OUTPUT
INSERT INTO RA8660 VALUES(@IdDoc, @LineNo, @ActNo, @DebetCredit,@IdDocDef,@DateTimeIdDoc, @p0, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10)
IF @DebetCredit=1
    SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2, @f3=-@f3, @f4=-@f4, @f5=-@f5, @f6=-@f6, @f7=-@f7, @f8=-@f8, @f9=-@f9, @f10=-@f10
IF @RepeatToTM=1 BEGIN
    SELECT @Period=@CurPeriod
    WHILE @Period<=@PeriodTA BEGIN
        EXECUTE _1sp_RG8660_Change @Period, @p0, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10
        EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
    END
END
ELSE
    EXECUTE _1sp_RG8660_Change @CurPeriod, @p0, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10
IF @SaveTurnsWithMonth=1 BEGIN
    EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
    EXECUTE _1sp_RG8660_Change @Period, @p0, @f0, @f1, @f2, @f3, @f4, @f5, @f6, @f7, @f8, @f9, @f10
END
\}
