F=PERIOD                |Period Registr      |D   |0     |0        
F=SP1678                |(P)ТоварС           |C   |9     |0        
F=SP1679                |(P)ТоварНа          |C   |9     |0        
F=SP9146                |(P)Док              |C   |13    |0        
F=SP1680                |(P)Флаг             |N   |1     |0        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG1677                      |PERIOD+PROP   |1     |PERIOD,SP1678,SP1679,SP9146                                 |1          
I=VIA1679                        |VIA1679       |0     |PERIOD,SP1679                                               |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG1677_Change            |              |@per D,@p1 C(9),@p2 C(9),@p3 C(13),@p4 N(1)|{\
Set Nocount On
Update RG1677
  set SP1680=Case When ABS(SP1680+@p4)>9 Then 9 Else SP1680+@p4 End
  where PERIOD=@per AND SP1678=@p1 AND SP1679=@p2 AND SP9146=@p3
if @@ROWCOUNT=0
    insert into RG1677 values(@per,@p1,@p2,@p3,@p4)
\}
