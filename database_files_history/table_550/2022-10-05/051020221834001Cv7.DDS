#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH8305_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,2),@Sum1 NUMERIC(28,2) 
SELECT @Sum0=COALESCE(SUM(SP8294),0),@Sum1=COALESCE(SUM(SP8295),0) FROM DT8305 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>999999999999.99 SELECT @Sum0=999999999999.99*SIGN(@Sum0)
    IF ABS(@Sum1)>999999999999.99 SELECT @Sum1=999999999999.99*SIGN(@Sum1)
UPDATE DH8305 SET SP8294=@Sum0,SP8295=@Sum1 WHERE IDDOC=@IdDoc
\}
