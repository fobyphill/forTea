#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH11044_UpdateTotals     |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4) 
SELECT @Sum0=COALESCE(SUM(SP11040),0) FROM DT11044 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
UPDATE DH11044 SET SP11040=@Sum0 WHERE IDDOC=@IdDoc
\}
