DECLARE Cur_RA13143 CURSOR FOR SELECT DEBKRED, SP13144, SP13145, SP13153, SP13154, SP13146, SP13147  FROM RA13143 WHERE IDDOC=@IdDoc
OPEN Cur_RA13143
FETCH NEXT FROM Cur_RA13143 INTO @DebetCredit, @p0, @p1, @p2, @p3, @f0, @f1
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG13143_Change @Period, @p0, @p1, @p2, @p3, @f0, @f1
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG13143_Change @CurPeriod, @p0, @p1, @p2, @p3, @f0, @f1
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG13143_Change @Period, @p0, @p1, @p2, @p3, @f0, @f1
    END

    FETCH NEXT FROM Cur_RA13143 INTO @DebetCredit, @p0, @p1, @p2, @p3, @f0, @f1
END
CLOSE Cur_RA13143
DEALLOCATE Cur_RA13143
\}
