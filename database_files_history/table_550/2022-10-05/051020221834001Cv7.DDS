  set SP9493=Case When ABS(SP9493+@p5)>999999999999.99 Then 999999999999.99 Else SP9493+@p5 End,SP11802=Case When ABS(SP11802+@p6)>99999999999.999 Then 99999999999.999 Else SP11802+@p6 End
  where PERIOD=@per AND SP11800=@p1 AND SP11801=@p2 AND SP9492=@p3 AND SP10396=@p4
if @@ROWCOUNT=0
    insert into RG9491 values(@per,@p1,@p2,@p3,@p4,@p5,@p6)
\}
