F=SP12856               |(P)Статья           |C   |13    |0        
F=SP12962               |(P)СуммаБезНДС      |N   |14    |4        
F=SP12858               |(P)НДС              |N   |14    |2        
F=SP12857               |(P)Сумма            |N   |14    |4        
F=SP13875               |(P)НаСделкуТЧ       |C   |9     |0        
F=SP13876               |(P)СтавкаНДС        |C   |9     |0        
F=SP13877               |(P)СуммаПоСделке    |N   |14    |4        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_DT12812                     |of IDDOC+LineN|1     |IDDOC,LINENO_                                               |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH12812_UpdateTotals     |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4),@Sum1 NUMERIC(28,2),@Sum2 NUMERIC(28,4),@Sum3 NUMERIC(28,4) 
SELECT @Sum0=COALESCE(SUM(SP12962),0),@Sum1=COALESCE(SUM(SP12858),0),@Sum2=COALESCE(SUM(SP12857),0),@Sum3=COALESCE(SUM(SP13877),0) FROM DT12812 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
    IF ABS(@Sum1)>999999999999.99 SELECT @Sum1=999999999999.99*SIGN(@Sum1)
    IF ABS(@Sum2)>9999999999.9999 SELECT @Sum2=9999999999.9999*SIGN(@Sum2)
    IF ABS(@Sum3)>9999999999.9999 SELECT @Sum3=9999999999.9999*SIGN(@Sum3)
UPDATE DH12812 SET SP12962=@Sum0,SP12858=@Sum1,SP12857=@Sum2,SP13877=@Sum3 WHERE IDDOC=@IdDoc
\}
