P=_1sp_RG5865_Change            |              |@per D,@p1 C(9),@p2 C(9),@p3 C(9),@p4 C(100),@p5 C(50),@p6 N(9,3),@p7 N(9,3)|{\
Set Nocount On
Update RG5865
  set SP5863=Case When ABS(SP5863+@p6)>999999.999 Then 999999.999 Else SP5863+@p6 End,SP5864=Case When ABS(SP5864+@p7)>999999.999 Then 999999.999 Else SP5864+@p7 End
  where PERIOD=@per AND SP5858=@p1 AND SP5859=@p2 AND SP5860=@p3 AND SP5861=@p4 AND SP5862=@p5
if @@ROWCOUNT=0
    insert into RG5865 values(@per,@p1,@p2,@p3,@p4,@p5,@p6,@p7)
\}
#
