F=SP5182                |(P)Товар            |C   |9     |0        
F=SP5183                |(P)ДатаМР           |D   |0     |0        
F=SP5184                |(P)Количество       |N   |14    |3        
F=SP5185                |(P)Сумма            |N   |14    |4        
F=SP5186                |(P)НДС              |N   |14    |4        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA5187                      |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
I=VIA5180                        |VIA5180       |1     |SP5180,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
I=VIA5181                        |VIA5181       |1     |SP5181,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
