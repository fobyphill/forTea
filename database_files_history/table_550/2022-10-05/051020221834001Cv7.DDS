#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG7852_Change            |              |@per D,@p1 C(13),@p2 C(9),@p3 C(9),@p4 C(9),@p5 N(14,4),@p6 N(14,4),@p7 N(14,4),@p8 N(14,2),@p9 N(14,4),@p10 N(10),@p11 N(14,2),@p12 N(14,2),@p13 N(14,2),@p14 N(14,2),@p15 N(14,3),@p16 N(14,2),@p17 N(14,2),@p18 N(14,2)|{\
Set Nocount On
Update RG7852
  set SP7842=Case When ABS(SP7842+@p5)>9999999999.9999 Then 9999999999.9999 Else SP7842+@p5 End,SP7843=Case When ABS(SP7843+@p6)>9999999999.9999 Then 9999999999.9999 Else SP7843+@p6 End,SP7844=Case When ABS(SP7844+@p7)>9999999999.9999 Then 9999999999.9999 Else SP7844+@p7 End,SP7845=Case When ABS(SP7845+@p8)>999999999999.99 Then 999999999999.99 Else SP7845+@p8 End,SP7846=Case When ABS(SP7846+@p9)>9999999999.9999 Then 9999999999.9999 Else SP7846+@p9 End,SP7848=Case When ABS(SP7848+@p10)>9999999999 Then 9999999999 Else SP7848+@p10 End,SP7950=Case When ABS(SP7950+@p11)>999999999999.99 Then 999999999999.99 Else SP7950+@p11 End,SP7951=Case When ABS(SP7951+@p12)>999999999999.99 Then 999999999999.99 Else SP7951+@p12 End,SP7952=Case When ABS(SP7952+@p13)>999999999999.99 Then 999999999999.99 Else SP7952+@p13 End,SP7953=Case When ABS(SP7953+@p14)>999999999999.99 Then 999999999999.99 Else SP7953+@p14 End,SP7960=Case When ABS(SP7960+@p15)>99999999999.999 Then 99999999999.999 Else SP7960+@p15 End,SP7974=Case When ABS(SP7974+@p16)>999999999999.99 Then 999999999999.99 Else SP7974+@p16 End,SP7975=Case When ABS(SP7975+@p17)>999999999999.99 Then 999999999999.99 Else SP7975+@p17 End,SP7976=Case When ABS(SP7976+@p18)>999999999999.99 Then 999999999999.99 Else SP7976+@p18 End
  where PERIOD=@per AND SP7838=@p1 AND SP7839=@p2 AND SP7840=@p3 AND SP7841=@p4
if @@ROWCOUNT=0
    insert into RG7852 values(@per,@p1,@p2,@p3,@p4,@p5,@p6,@p7,@p8,@p9,@p10,@p11,@p12,@p13,@p14,@p15,@p16,@p17,@p18)
\}
