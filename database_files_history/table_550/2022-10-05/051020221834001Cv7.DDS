T=RG9046  |Регистр РасчетныеДокументыПоСч|RG9046     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP9042                |(P)Счет             |C   |13    |0        
F=SP9043                |(P)РасчетныйДокумент|C   |13    |0        
F=SP9668                |(P)АвансУЕ          |N   |14    |4        
F=SP9669                |(P)АвансРуб         |N   |14    |2        
F=SP9670                |(P)КредитУЕ         |N   |14    |4        
F=SP9671                |(P)КредитРуб        |N   |14    |2        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG9046                      |PERIOD+PROP   |1     |PERIOD,SP9042,SP9043                                        |1          
I=VIA9043                        |VIA9043       |0     |PERIOD,SP9043                                               |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG9046_Change            |              |@per D,@p1 C(13),@p2 C(13),@p3 N(14,4),@p4 N(14,2),@p5 N(14,4),@p6 N(14,2)|{\
Set Nocount On
Update RG9046
  set SP9668=Case When ABS(SP9668+@p3)>9999999999.9999 Then 9999999999.9999 Else SP9668+@p3 End,SP9669=Case When ABS(SP9669+@p4)>999999999999.99 Then 999999999999.99 Else SP9669+@p4 End,SP9670=Case When ABS(SP9670+@p5)>9999999999.9999 Then 9999999999.9999 Else SP9670+@p5 End,SP9671=Case When ABS(SP9671+@p6)>999999999999.99 Then 999999999999.99 Else SP9671+@p6 End
  where PERIOD=@per AND SP9042=@p1 AND SP9043=@p2
if @@ROWCOUNT=0
    insert into RG9046 values(@per,@p1,@p2,@p3,@p4,@p5,@p6)
\}
