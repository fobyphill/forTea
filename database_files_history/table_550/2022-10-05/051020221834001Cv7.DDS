SELECT @Sum0=COALESCE(SUM(SP7688),0),@Sum1=COALESCE(SUM(SP7689),0),@Sum2=COALESCE(SUM(SP7692),0),@Sum3=COALESCE(SUM(SP7697),0),@Sum4=COALESCE(SUM(SP7698),0) FROM DT7705 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>99999999999.999 SELECT @Sum0=99999999999.999*SIGN(@Sum0)
    IF ABS(@Sum1)>9999999999.9999 SELECT @Sum1=9999999999.9999*SIGN(@Sum1)
    IF ABS(@Sum2)>9999999999.9999 SELECT @Sum2=9999999999.9999*SIGN(@Sum2)
    IF ABS(@Sum3)>9999999999.9999 SELECT @Sum3=9999999999.9999*SIGN(@Sum3)
    IF ABS(@Sum4)>9999999999.9999 SELECT @Sum4=9999999999.9999*SIGN(@Sum4)
UPDATE DH7705 SET SP7688=@Sum0,SP7689=@Sum1,SP7692=@Sum2,SP7697=@Sum3,SP7698=@Sum4 WHERE IDDOC=@IdDoc
\}
