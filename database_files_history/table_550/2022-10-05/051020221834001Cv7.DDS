#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA737_ClearRecalcDocActs |              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(9), @p2 NUMERIC(5, 2), @p3 CHAR(13), @p4 CHAR(9), @p5 CHAR(9), @f0 NUMERIC(14, 4), @f1 NUMERIC(14, 4)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA737 CURSOR FOR SELECT DEBKRED, SP738, SP739, SP1957, SP741, SP1958, SP3759, SP740, SP2209  FROM RA737 WHERE IDDOC=@IdDoc
OPEN Cur_RA737
FETCH NEXT FROM Cur_RA737 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @p5, @f0, @f1
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG737_Change @Period, @p0, @p1, @p2, @p3, @p4, @p5, @f0, @f1
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG737_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @p5, @f0, @f1
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG737_Change @Period, @p0, @p1, @p2, @p3, @p4, @p5, @f0, @f1
    END

    FETCH NEXT FROM Cur_RA737 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @p5, @f0, @f1
END
CLOSE Cur_RA737
DEALLOCATE Cur_RA737
\}
