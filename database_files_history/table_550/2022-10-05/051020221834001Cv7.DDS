P=_1sp_DH3803_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,3),@Sum1 NUMERIC(28,2),@Sum2 NUMERIC(28,2) 
SELECT @Sum0=COALESCE(SUM(SP3829),0),@Sum1=COALESCE(SUM(SP3830),0),@Sum2=COALESCE(SUM(SP3831),0) FROM DT3803 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>99999999999.999 SELECT @Sum0=99999999999.999*SIGN(@Sum0)
    IF ABS(@Sum1)>999999999999.99 SELECT @Sum1=999999999999.99*SIGN(@Sum1)
    IF ABS(@Sum2)>999999999999.99 SELECT @Sum2=999999999999.99*SIGN(@Sum2)
UPDATE DH3803 SET SP3829=@Sum0,SP3830=@Sum1,SP3831=@Sum2 WHERE IDDOC=@IdDoc
\}
