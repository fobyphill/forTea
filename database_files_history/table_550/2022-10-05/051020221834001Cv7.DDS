F=IDDOCDEF              |ID Def Document     |I   |0     |0        
F=DATE_TIME_IDDOC       |Date+Time+IDDoc     |C   |23    |0        
F=SP3445                |(P)Договор          |C   |13    |0        
F=SP3440                |(P)Товар            |C   |9     |0        
F=SP3442                |(P)Модель           |C   |9     |0        
F=SP3443                |(P)Дислокация       |C   |9     |0        
F=SP3444                |(P)СерНомер         |C   |13    |0        
F=SP3441                |(P)Количество       |N   |14    |3        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA3439                      |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
I=VIA3444                        |VIA3444       |1     |SP3444,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA3439_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @p1 CHAR(9), @p2 CHAR(9), @p3 CHAR(9), @p4 CHAR(13), @f0 NUMERIC(14, 3)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA3439 CURSOR FOR SELECT DEBKRED, SP3445, SP3440, SP3442, SP3443, SP3444, SP3441  FROM RA3439 WHERE IDDOC=@IdDoc
OPEN Cur_RA3439
FETCH NEXT FROM Cur_RA3439 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @f0
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG3439_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG3439_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @f0
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG3439_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0
    END

    FETCH NEXT FROM Cur_RA3439 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @f0
END
CLOSE Cur_RA3439
DEALLOCATE Cur_RA3439
\}
