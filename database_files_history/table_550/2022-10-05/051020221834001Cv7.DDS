#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH7461_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,3) 
SELECT @Sum0=COALESCE(SUM(SP7451),0) FROM DT7461 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>99999999999.999 SELECT @Sum0=99999999999.999*SIGN(@Sum0)
UPDATE DH7461 SET SP7451=@Sum0 WHERE IDDOC=@IdDoc
\}
