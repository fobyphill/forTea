P=_1sp_RG7009_TLockX            |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RG7009(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 690    : Регистр ТоварыНаСкладахНазначения
# Name    |Descr                         |SQLTableNam|RecordLock
T=RG7009  |Регистр ТоварыНаСкладахНазначе|RG7009     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP7002                |(P)ДокументСчет     |C   |13    |0        
F=SP7003                |(P)СкладНахождения  |C   |9     |0        
F=SP7004                |(P)СкладНазначения  |C   |9     |0        
F=SP7260                |(P)УзелНазначения   |C   |9     |0        
F=SP7005                |(P)Товар            |C   |9     |0        
F=SP7006                |(P)Количество       |N   |14    |3        
F=SP7007                |(P)Сумма            |N   |14    |4        
F=SP7008                |(P)НДС              |N   |14    |4        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG7009                      |PERIOD+PROP   |1     |PERIOD,SP7002,SP7003,SP7004,SP7260,SP7005                   |1          
I=VIA7003                        |VIA7003       |0     |PERIOD,SP7003                                               |0          
I=VIA7004                        |VIA7004       |0     |PERIOD,SP7004                                               |0          
I=VIA7260                        |VIA7260       |0     |PERIOD,SP7260                                               |0          
I=VIA7005                        |VIA7005       |0     |PERIOD,SP7005                                               |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG7009_Change            |              |@per D,@p1 C(13),@p2 C(9),@p3 C(9),@p4 C(9),@p5 C(9),@p6 N(14,3),@p7 N(14,4),@p8 N(14,4)|{\
Set Nocount On
Update RG7009
  set SP7006=Case When ABS(SP7006+@p6)>99999999999.999 Then 99999999999.999 Else SP7006+@p6 End,SP7007=Case When ABS(SP7007+@p7)>9999999999.9999 Then 9999999999.9999 Else SP7007+@p7 End,SP7008=Case When ABS(SP7008+@p8)>9999999999.9999 Then 9999999999.9999 Else SP7008+@p8 End
  where PERIOD=@per AND SP7002=@p1 AND SP7003=@p2 AND SP7004=@p3 AND SP7260=@p4 AND SP7005=@p5
if @@ROWCOUNT=0
    insert into RG7009 values(@per,@p1,@p2,@p3,@p4,@p5,@p6,@p7,@p8)
\}
