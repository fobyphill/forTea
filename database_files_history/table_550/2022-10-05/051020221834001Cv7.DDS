#
#===============================================================================
#==PROCEDURE EscalateTLockX
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG12432_TLockX           |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RG12432(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 754    : Регистр АктивныеДоговора
# Name    |Descr                         |SQLTableNam|RecordLock
T=RG12432 |Регистр АктивныеДоговора      |RG12432    |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP12430               |(P)Договор          |C   |13    |0        
F=SP12431               |(P)Активность       |N   |1     |0        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG12432                     |PERIOD+PROP   |1     |PERIOD,SP12430                                              |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG12432_Change           |              |@per D,@p1 C(13),@p2 N(1)               |{\
Set Nocount On
Update RG12432
  set SP12431=Case When ABS(SP12431+@p2)>9 Then 9 Else SP12431+@p2 End
  where PERIOD=@per AND SP12430=@p1
if @@ROWCOUNT=0
    insert into RG12432 values(@per,@p1,@p2)
\}
