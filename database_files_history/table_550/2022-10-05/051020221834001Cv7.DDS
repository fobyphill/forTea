P=_1sp_DT14840_TLock            |EscalateTLock |                                        |set nocount on declare @i integer select @i=1 from DT14840(TABLOCK HOLDLOCK) where 0=1
#
#===============================================================================
#==PROCEDURE EscalateTLockX
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DT14840_TLockX           |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from DT14840(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 595    : Документ (Мн.ч.) ПереносОбязательствПоДоходам
# Name    |Descr                         |SQLTableNam|RecordLock
T=DT14840 |Документ (Мн.ч.) ПереносОбязат|DT14840    |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=IDDOC                 |ID Document's       |C   |9     |0        
F=LINENO_               |LineNo              |S   |0     |0        
F=SP14848               |(P)Подразделение    |C   |9     |0        
F=SP14849               |(P)Сделка           |C   |9     |0        
F=SP14850               |(P)Статья           |C   |13    |0        
F=SP14851               |(P)СуммаБезНДС      |N   |14    |4        
F=SP14852               |(P)НДС              |N   |14    |2        
F=SP14853               |(P)Сумма            |N   |14    |4        
F=SP14854               |(P)НаСделкуТЧ       |C   |9     |0        
F=SP14855               |(P)СтавкаНДС        |C   |9     |0        
F=SP14856               |(P)СуммаПоСделке    |N   |14    |4        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_DT14840                     |of IDDOC+LineN|1     |IDDOC,LINENO_                                               |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH14840_UpdateTotals     |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4),@Sum1 NUMERIC(28,2),@Sum2 NUMERIC(28,4),@Sum3 NUMERIC(28,4) 
SELECT @Sum0=COALESCE(SUM(SP14851),0),@Sum1=COALESCE(SUM(SP14852),0),@Sum2=COALESCE(SUM(SP14853),0),@Sum3=COALESCE(SUM(SP14856),0) FROM DT14840 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
    IF ABS(@Sum1)>999999999999.99 SELECT @Sum1=999999999999.99*SIGN(@Sum1)
    IF ABS(@Sum2)>9999999999.9999 SELECT @Sum2=9999999999.9999*SIGN(@Sum2)
    IF ABS(@Sum3)>9999999999.9999 SELECT @Sum3=9999999999.9999*SIGN(@Sum3)
UPDATE DH14840 SET SP14851=@Sum0,SP14852=@Sum1,SP14853=@Sum2,SP14856=@Sum3 WHERE IDDOC=@IdDoc
\}
