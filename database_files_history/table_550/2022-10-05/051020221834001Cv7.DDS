DECLARE @Sum0 NUMERIC(28,2),@Sum1 NUMERIC(28,2) 
SELECT @Sum0=COALESCE(SUM(SP14301),0),@Sum1=COALESCE(SUM(SP14302),0) FROM DT14311 WHERE IDDOC=@IdDoc
