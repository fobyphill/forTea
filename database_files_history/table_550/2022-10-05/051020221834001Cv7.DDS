#
#===============================================================================
#==TABLE no 657    : Регистр (Дв.) ПеремещаемыйРезерв
# Name    |Descr                         |SQLTableNam|RecordLock
T=RA4625  |Регистр (Дв.) ПеремещаемыйРезе|RA4625     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=IDDOC                 |ID Document's       |C   |9     |0        
F=LINENO_               |LineNo              |S   |0     |0        
F=ACTNO                 |Action No           |I   |0     |0        
F=DEBKRED               |Flag Debet/Kredit   |L   |0     |0        
F=SP6758                |(P)ДокументСчет     |C   |9     |0        
F=SP6759                |(P)ДокументРезерв   |C   |9     |0        
F=SP6760                |(P)СкладОтправитель |C   |9     |0        
F=SP6761                |(P)СкладПолучатель  |C   |9     |0        
F=SP4622                |(P)Товар            |C   |9     |0        
F=SP4624                |(P)Количество       |N   |14    |3        
F=SP6762                |(P)Сумма            |N   |14    |4        
F=SP6763                |(P)НДС              |N   |14    |4        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA4625                      |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA4625_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(9), @p2 CHAR(9), @p3 CHAR(9), @p4 CHAR(9), @f0 NUMERIC(14, 3), @f1 NUMERIC(14, 4), @f2 NUMERIC(14, 4)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA4625 CURSOR FOR SELECT DEBKRED, SP6758, SP6759, SP6760, SP6761, SP4622, SP4624, SP6762, SP6763  FROM RA4625 WHERE IDDOC=@IdDoc
OPEN Cur_RA4625
FETCH NEXT FROM Cur_RA4625 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG4625_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG4625_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG4625_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2
    END

    FETCH NEXT FROM Cur_RA4625 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2
END
CLOSE Cur_RA4625
DEALLOCATE Cur_RA4625
\}
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA4625_WriteDocAct       |              |@IdDoc C(9), @LineNo S, @ActNo I, @DebetCredit L, @p0 C(9), @p1 C(9), @p2 C(9), @p3 C(9), @p4 C(9), @f0 N(14,3), @f1 N(14,4), @f2 N(14,4), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM

EXECUTE _1sp_GetBeginOfPeriod @PeriodTA, @SnapShotPeriod, @PeriodTA OUTPUT
INSERT INTO RA4625 VALUES(@IdDoc, @LineNo, @ActNo, @DebetCredit, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2)
IF @DebetCredit=1
    SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2
IF @RepeatToTM=1 BEGIN
    SELECT @Period=@CurPeriod
    WHILE @Period<=@PeriodTA BEGIN
        EXECUTE _1sp_RG4625_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2
        EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
    END
END
ELSE
    EXECUTE _1sp_RG4625_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2
IF @SaveTurnsWithMonth=1 BEGIN
    EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
    EXECUTE _1sp_RG4625_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2
END
\}
