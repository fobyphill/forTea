I=PK_RG13291                     |PERIOD+PROP   |1     |PERIOD,SP14254,SP14255,SP14256                              |1          
I=VIA14255                       |VIA14255      |0     |PERIOD,SP14255                                              |0          
I=VIA14256                       |VIA14256      |0     |PERIOD,SP14256                                              |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG13291_Change           |              |@per D,@p1 C(9),@p2 C(9),@p3 C(9),@p4 N(14,2),@p5 N(14,2)|{\
Set Nocount On
Update RG13291
  set SP14257=Case When ABS(SP14257+@p4)>999999999999.99 Then 999999999999.99 Else SP14257+@p4 End,SP14258=Case When ABS(SP14258+@p5)>999999999999.99 Then 999999999999.99 Else SP14258+@p5 End
  where PERIOD=@per AND SP14254=@p1 AND SP14255=@p2 AND SP14256=@p3
if @@ROWCOUNT=0
    insert into RG13291 values(@per,@p1,@p2,@p3,@p4,@p5)
\}
