F=PERIOD                |Period Registr      |D   |0     |0        
F=SP13721               |(P)новый1           |C   |13    |0        
F=SP13722               |(P)новый2           |N   |10    |0        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG13720                     |PERIOD+PROP   |1     |PERIOD,SP13721                                              |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG13720_Change           |              |@per D,@p1 C(13),@p2 N(10)              |{\
Set Nocount On
Update RG13720
  set SP13722=Case When ABS(SP13722+@p2)>9999999999 Then 9999999999 Else SP13722+@p2 End
  where PERIOD=@per AND SP13721=@p1
if @@ROWCOUNT=0
    insert into RG13720 values(@per,@p1,@p2)
\}
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG13720_Select           |              |@per D,@p1 C(13),@p2 N(10) O            |Select @p2=SP13722 from RG13720 where PERIOD=@per AND SP13721=@p1
#
#===============================================================================
#==PROCEDURE EscalateTLock
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA13720_TLock            |EscalateTLock |                                        |set nocount on declare @i integer select @i=1 from RA13720(TABLOCK HOLDLOCK) where 0=1
#
#===============================================================================
#==PROCEDURE EscalateTLockX
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA13720_TLockX           |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RA13720(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 777    : Регистр (Дв.) Резерв212
# Name    |Descr                         |SQLTableNam|RecordLock
T=RA13720 |Регистр (Дв.) Резерв212       |RA13720    |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=IDDOC                 |ID Document's       |C   |9     |0        
F=LINENO_               |LineNo              |S   |0     |0        
F=ACTNO                 |Action No           |I   |0     |0        
F=DEBKRED               |Flag Debet/Kredit   |L   |0     |0        
F=SP13721               |(P)новый1           |C   |13    |0        
F=SP13722               |(P)новый2           |N   |10    |0        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA13720                     |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA13720_ClearRecalcDocAct|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @f0 NUMERIC(10, 0)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA13720 CURSOR FOR SELECT DEBKRED, SP13721, SP13722  FROM RA13720 WHERE IDDOC=@IdDoc
OPEN Cur_RA13720
FETCH NEXT FROM Cur_RA13720 INTO @DebetCredit, @p0, @f0
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG13720_Change @Period, @p0, @f0
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG13720_Change @CurPeriod, @p0, @f0
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG13720_Change @Period, @p0, @f0
    END

    FETCH NEXT FROM Cur_RA13720 INTO @DebetCredit, @p0, @f0
END
CLOSE Cur_RA13720
DEALLOCATE Cur_RA13720
\}
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA13720_WriteDocAct      |              |@IdDoc C(9), @LineNo S, @ActNo I, @DebetCredit L, @p0 C(13), @f0 N(10), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM

EXECUTE _1sp_GetBeginOfPeriod @PeriodTA, @SnapShotPeriod, @PeriodTA OUTPUT
INSERT INTO RA13720 VALUES(@IdDoc, @LineNo, @ActNo, @DebetCredit, @p0, @f0)
IF @DebetCredit=1
    SELECT @f0=-@f0
IF @RepeatToTM=1 BEGIN
    SELECT @Period=@CurPeriod
    WHILE @Period<=@PeriodTA BEGIN
        EXECUTE _1sp_RG13720_Change @Period, @p0, @f0
        EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
    END
END
ELSE
    EXECUTE _1sp_RG13720_Change @CurPeriod, @p0, @f0
IF @SaveTurnsWithMonth=1 BEGIN
    EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
    EXECUTE _1sp_RG13720_Change @Period, @p0, @f0
END
\}
