P=_1sp_DT8125_TLockX            |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from DT8125(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 441    : Документ (Мн.ч.) РРс
# Name    |Descr                         |SQLTableNam|RecordLock
T=DT8125  |Документ (Мн.ч.) РРс          |DT8125     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=IDDOC                 |ID Document's       |C   |9     |0        
F=LINENO_               |LineNo              |S   |0     |0        
F=SP8120                |(P)Сумма_процент    |N   |14    |2        
F=SP8121                |(P)Сделка           |C   |9     |0        
F=SP8122                |(P)Сумма_невыбор    |N   |14    |2        
F=SP8123                |(P)Договор          |C   |9     |0        
F=SP9160                |(P)Дельта_процент   |N   |14    |3        
F=SP9161                |(P)Дельта_невыбор   |N   |14    |3        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_DT8125                      |of IDDOC+LineN|1     |IDDOC,LINENO_                                               |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH8125_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,2),@Sum1 NUMERIC(28,3),@Sum2 NUMERIC(28,3) 
SELECT @Sum0=COALESCE(SUM(SP8120),0),@Sum1=COALESCE(SUM(SP9160),0),@Sum2=COALESCE(SUM(SP9161),0) FROM DT8125 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>999999999999.99 SELECT @Sum0=999999999999.99*SIGN(@Sum0)
    IF ABS(@Sum1)>99999999999.999 SELECT @Sum1=99999999999.999*SIGN(@Sum1)
    IF ABS(@Sum2)>99999999999.999 SELECT @Sum2=99999999999.999*SIGN(@Sum2)
UPDATE DH8125 SET SP8120=@Sum0,SP9160=@Sum1,SP9161=@Sum2 WHERE IDDOC=@IdDoc
\}
