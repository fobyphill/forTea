F=IDDOCDEF              |ID Def Document     |I   |0     |0        
F=DATE_TIME_IDDOC       |Date+Time+IDDoc     |C   |23    |0        
F=SP7002                |(P)ДокументСчет     |C   |13    |0        
F=SP7003                |(P)СкладНахождения  |C   |9     |0        
F=SP7004                |(P)СкладНазначения  |C   |9     |0        
F=SP7260                |(P)УзелНазначения   |C   |9     |0        
F=SP7005                |(P)Товар            |C   |9     |0        
F=SP7006                |(P)Количество       |N   |14    |3        
F=SP7007                |(P)Сумма            |N   |14    |4        
F=SP7008                |(P)НДС              |N   |14    |4        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA7009                      |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
I=VIA7002                        |VIA7002       |1     |SP7002,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
I=VIA7003                        |VIA7003       |1     |SP7003,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
I=VIA7004                        |VIA7004       |1     |SP7004,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
I=VIA7260                        |VIA7260       |1     |SP7260,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
I=VIA7005                        |VIA7005       |1     |SP7005,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA7009_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @p1 CHAR(9), @p2 CHAR(9), @p3 CHAR(9), @p4 CHAR(9), @f0 NUMERIC(14, 3), @f1 NUMERIC(14, 4), @f2 NUMERIC(14, 4)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA7009 CURSOR FOR SELECT DEBKRED, SP7002, SP7003, SP7004, SP7260, SP7005, SP7006, SP7007, SP7008  FROM RA7009 WHERE IDDOC=@IdDoc
OPEN Cur_RA7009
FETCH NEXT FROM Cur_RA7009 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG7009_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG7009_Change @CurPeriod, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG7009_Change @Period, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2
    END

    FETCH NEXT FROM Cur_RA7009 INTO @DebetCredit, @p0, @p1, @p2, @p3, @p4, @f0, @f1, @f2
END
CLOSE Cur_RA7009
DEALLOCATE Cur_RA7009
\}
