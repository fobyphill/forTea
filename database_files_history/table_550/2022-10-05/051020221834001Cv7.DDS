#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA5118_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @p1 CHAR(13), @p2 CHAR(9), @f0 NUMERIC(14, 3), @f1 NUMERIC(14, 4)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA5118 CURSOR FOR SELECT DEBKRED, SP5106, SP5107, SP5108, SP5109, SP5110  FROM RA5118 WHERE IDDOC=@IdDoc
OPEN Cur_RA5118
FETCH NEXT FROM Cur_RA5118 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG5118_Change @Period, @p0, @p1, @p2, @f0, @f1
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG5118_Change @CurPeriod, @p0, @p1, @p2, @f0, @f1
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG5118_Change @Period, @p0, @p1, @p2, @f0, @f1
    END

    FETCH NEXT FROM Cur_RA5118 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1
END
CLOSE Cur_RA5118
DEALLOCATE Cur_RA5118
\}
