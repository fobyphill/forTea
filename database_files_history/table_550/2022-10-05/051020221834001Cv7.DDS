P=_1sp_RG11391_Change           |              |@per D,@p1 C(13),@p2 C(9),@p3 C(13),@p4 N(14,2)|{\
Set Nocount On
Update RG11391
  set SP11395=Case When ABS(SP11395+@p4)>999999999999.99 Then 999999999999.99 Else SP11395+@p4 End
  where PERIOD=@per AND SP11392=@p1 AND SP11393=@p2 AND SP11394=@p3
if @@ROWCOUNT=0
    insert into RG11391 values(@per,@p1,@p2,@p3,@p4)
\}
