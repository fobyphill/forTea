P=_1sp_RG1859_Change            |              |@per D,@p1 C(9),@p2 C(9),@p3 N(14,2),@p4 N(14,2)|{\
Set Nocount On
Update RG1859
  set SP1861=Case When ABS(SP1861+@p3)>999999999999.99 Then 999999999999.99 Else SP1861+@p3 End,SP2729=Case When ABS(SP2729+@p4)>999999999999.99 Then 999999999999.99 Else SP2729+@p4 End
  where PERIOD=@per AND SP1860=@p1 AND SP2724=@p2
if @@ROWCOUNT=0
    insert into RG1859 values(@per,@p1,@p2,@p3,@p4)
\}
