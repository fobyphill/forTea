#
#===============================================================================
#==TABLE no 701    : Регистр (Дв.) РезервыОжидания
# Name    |Descr                         |SQLTableNam|RecordLock
T=RA7618  |Регистр (Дв.) РезервыОжидания |RA7618     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=IDDOC                 |ID Document's       |C   |9     |0        
F=LINENO_               |LineNo              |S   |0     |0        
F=ACTNO                 |Action No           |I   |0     |0        
F=DEBKRED               |Flag Debet/Kredit   |L   |0     |0        
F=IDDOCDEF              |ID Def Document     |I   |0     |0        
F=DATE_TIME_IDDOC       |Date+Time+IDDoc     |C   |23    |0        
F=SP7607                |(P)СчетПоставщика   |C   |13    |0        
F=SP7608                |(P)ДокументСчет     |C   |13    |0        
F=SP7610                |(P)Товар            |C   |9     |0        
F=SP7612                |(P)Количество       |N   |14    |3        
F=SP7613                |(P)КоличествоВсего  |N   |14    |3        
F=SP7614                |(P)Сумма            |N   |14    |4        
F=SP7615                |(P)СуммаВсего       |N   |14    |4        
F=SP7616                |(P)НДС              |N   |14    |4        
F=SP7617                |(P)НДСВсего         |N   |14    |4        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA7618                      |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
