P=_1sp_RA1580_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
