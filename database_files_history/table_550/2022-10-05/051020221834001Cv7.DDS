#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH6262_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,3),@Sum1 NUMERIC(28,3) 
SELECT @Sum0=COALESCE(SUM(SP6252),0),@Sum1=COALESCE(SUM(SP6253),0) FROM DT6262 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>99999999999.999 SELECT @Sum0=99999999999.999*SIGN(@Sum0)
    IF ABS(@Sum1)>99999999999.999 SELECT @Sum1=99999999999.999*SIGN(@Sum1)
UPDATE DH6262 SET SP6252=@Sum0,SP6253=@Sum1 WHERE IDDOC=@IdDoc
\}
