P=_1sp_DH13666_UpdateTotals     |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4),@Sum1 NUMERIC(28,2) 
SELECT @Sum0=COALESCE(SUM(SP13664),0),@Sum1=COALESCE(SUM(SP13708),0) FROM DT13666 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
    IF ABS(@Sum1)>999999999999.99 SELECT @Sum1=999999999999.99*SIGN(@Sum1)
UPDATE DH13666 SET SP13664=@Sum0,SP13708=@Sum1 WHERE IDDOC=@IdDoc
\}
