#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA5187_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(13), @p2 CHAR(9), @p3 DATETIME, @f0 NUMERIC(14, 3), @f1 NUMERIC(14, 4), @f2 NUMERIC(14, 4)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA5187 CURSOR FOR SELECT DEBKRED, SP5180, SP5181, SP5182, SP5183, SP5184, SP5185, SP5186  FROM RA5187 WHERE IDDOC=@IdDoc
OPEN Cur_RA5187
FETCH NEXT FROM Cur_RA5187 INTO @DebetCredit, @p0, @p1, @p2, @p3, @f0, @f1, @f2
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG5187_Change @Period, @p0, @p1, @p2, @p3, @f0, @f1, @f2
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG5187_Change @CurPeriod, @p0, @p1, @p2, @p3, @f0, @f1, @f2
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG5187_Change @Period, @p0, @p1, @p2, @p3, @f0, @f1, @f2
    END

    FETCH NEXT FROM Cur_RA5187 INTO @DebetCredit, @p0, @p1, @p2, @p3, @f0, @f1, @f2
END
CLOSE Cur_RA5187
DEALLOCATE Cur_RA5187
\}
