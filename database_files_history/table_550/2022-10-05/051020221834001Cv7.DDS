I=VIA11245                       |VIA11245      |1     |SP11245,DATE_TIME_IDDOC,LINENO_,ACTNO                       |0          
I=VIA11246                       |VIA11246      |1     |SP11246,DATE_TIME_IDDOC,LINENO_,ACTNO                       |0          
