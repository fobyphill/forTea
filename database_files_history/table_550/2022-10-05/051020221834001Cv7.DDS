P=_1sp_RA9503_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(9), @p2 CHAR(9), @f0 NUMERIC(9, 3), @f1 NUMERIC(2, 0), @f2 NUMERIC(14, 4)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA9503 CURSOR FOR SELECT DEBKRED, SP9504, SP10738, SP10739, SP9505, SP11270, SP11296  FROM RA9503 WHERE IDDOC=@IdDoc
OPEN Cur_RA9503
FETCH NEXT FROM Cur_RA9503 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1, @f2
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1, @f2=-@f2
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG9503_Change @Period, @p0, @p1, @p2, @f0, @f1, @f2
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG9503_Change @CurPeriod, @p0, @p1, @p2, @f0, @f1, @f2
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG9503_Change @Period, @p0, @p1, @p2, @f0, @f1, @f2
    END

    FETCH NEXT FROM Cur_RA9503 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1, @f2
END
CLOSE Cur_RA9503
DEALLOCATE Cur_RA9503
\}
