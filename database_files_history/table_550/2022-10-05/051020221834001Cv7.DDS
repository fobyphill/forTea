I=PK_DT2311                      |of IDDOC+LineN|1     |IDDOC,LINENO_                                               |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH2311_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4),@Sum1 NUMERIC(28,2) 
SELECT @Sum0=COALESCE(SUM(SP2336),0),@Sum1=COALESCE(SUM(SP2337),0) FROM DT2311 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
    IF ABS(@Sum1)>999999999999.99 SELECT @Sum1=999999999999.99*SIGN(@Sum1)
UPDATE DH2311 SET SP2336=@Sum0,SP2337=@Sum1 WHERE IDDOC=@IdDoc
\}
