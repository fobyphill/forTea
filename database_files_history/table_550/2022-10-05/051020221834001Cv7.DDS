#
#===============================================================================
#==TABLE no 771    : Регистр (Дв.) Резерв2
# Name    |Descr                         |SQLTableNam|RecordLock
T=RA13291 |Регистр (Дв.) Резерв2         |RA13291    |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=IDDOC                 |ID Document's       |C   |9     |0        
F=LINENO_               |LineNo              |S   |0     |0        
F=ACTNO                 |Action No           |I   |0     |0        
F=DEBKRED               |Flag Debet/Kredit   |L   |0     |0        
F=IDDOCDEF              |ID Def Document     |I   |0     |0        
F=DATE_TIME_IDDOC       |Date+Time+IDDoc     |C   |23    |0        
F=SP14254               |(P)Договор          |C   |9     |0        
F=SP14255               |(P)ФирмаОтправитель |C   |9     |0        
F=SP14256               |(P)ФирмаПолучатель  |C   |9     |0        
F=SP14257               |(P)Сумма            |N   |14    |2        
F=SP14258               |(P)НДС              |N   |14    |2        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA13291                     |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
I=VIA14254                       |VIA14254      |1     |SP14254,DATE_TIME_IDDOC,LINENO_,ACTNO                       |0          
I=VIA14255                       |VIA14255      |1     |SP14255,DATE_TIME_IDDOC,LINENO_,ACTNO                       |0          
I=VIA14256                       |VIA14256      |1     |SP14256,DATE_TIME_IDDOC,LINENO_,ACTNO                       |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA13291_ClearRecalcDocAct|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(9), @p1 CHAR(9), @p2 CHAR(9), @f0 NUMERIC(14, 2), @f1 NUMERIC(14, 2)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA13291 CURSOR FOR SELECT DEBKRED, SP14254, SP14255, SP14256, SP14257, SP14258  FROM RA13291 WHERE IDDOC=@IdDoc
OPEN Cur_RA13291
FETCH NEXT FROM Cur_RA13291 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0, @f1=-@f1
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG13291_Change @Period, @p0, @p1, @p2, @f0, @f1
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG13291_Change @CurPeriod, @p0, @p1, @p2, @f0, @f1
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG13291_Change @Period, @p0, @p1, @p2, @f0, @f1
    END

    FETCH NEXT FROM Cur_RA13291 INTO @DebetCredit, @p0, @p1, @p2, @f0, @f1
END
CLOSE Cur_RA13291
DEALLOCATE Cur_RA13291
\}
#
