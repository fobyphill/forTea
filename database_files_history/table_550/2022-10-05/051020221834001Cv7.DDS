#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH9292_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4) 
SELECT @Sum0=COALESCE(SUM(SP9663),0) FROM DT9292 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
UPDATE DH9292 SET SP9663=@Sum0 WHERE IDDOC=@IdDoc
\}
