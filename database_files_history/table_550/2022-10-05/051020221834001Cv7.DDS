F=SP7616                |(P)НДС              |N   |14    |4        
F=SP7617                |(P)НДСВсего         |N   |14    |4        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG7618                      |PERIOD+PROP   |1     |PERIOD,SP7607,SP7608,SP7610                                 |1          
I=VIA7608                        |VIA7608       |0     |PERIOD,SP7608                                               |0          
I=VIA7610                        |VIA7610       |0     |PERIOD,SP7610                                               |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG7618_Change            |              |@per D,@p1 C(13),@p2 C(13),@p3 C(9),@p4 N(14,3),@p5 N(14,3),@p6 N(14,4),@p7 N(14,4),@p8 N(14,4),@p9 N(14,4)|{\
Set Nocount On
Update RG7618
  set SP7612=Case When ABS(SP7612+@p4)>99999999999.999 Then 99999999999.999 Else SP7612+@p4 End,SP7613=Case When ABS(SP7613+@p5)>99999999999.999 Then 99999999999.999 Else SP7613+@p5 End,SP7614=Case When ABS(SP7614+@p6)>9999999999.9999 Then 9999999999.9999 Else SP7614+@p6 End,SP7615=Case When ABS(SP7615+@p7)>9999999999.9999 Then 9999999999.9999 Else SP7615+@p7 End,SP7616=Case When ABS(SP7616+@p8)>9999999999.9999 Then 9999999999.9999 Else SP7616+@p8 End,SP7617=Case When ABS(SP7617+@p9)>9999999999.9999 Then 9999999999.9999 Else SP7617+@p9 End
  where PERIOD=@per AND SP7607=@p1 AND SP7608=@p2 AND SP7610=@p3
if @@ROWCOUNT=0
    insert into RG7618 values(@per,@p1,@p2,@p3,@p4,@p5,@p6,@p7,@p8,@p9)
\}
