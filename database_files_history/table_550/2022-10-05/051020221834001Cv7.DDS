#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH13398_UpdateTotals     |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4),@Sum1 NUMERIC(28,3),@Sum2 NUMERIC(28,4),@Sum3 NUMERIC(28,2) 
SELECT @Sum0=COALESCE(SUM(SP13432),0),@Sum1=COALESCE(SUM(SP13452),0),@Sum2=COALESCE(SUM(SP13454),0),@Sum3=COALESCE(SUM(SP13571),0) FROM DT13398 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
    IF ABS(@Sum1)>99999999999.999 SELECT @Sum1=99999999999.999*SIGN(@Sum1)
    IF ABS(@Sum2)>9999999999.9999 SELECT @Sum2=9999999999.9999*SIGN(@Sum2)
    IF ABS(@Sum3)>999.99 SELECT @Sum3=999.99*SIGN(@Sum3)
UPDATE DH13398 SET SP13432=@Sum0,SP13452=@Sum1,SP13454=@Sum2,SP13571=@Sum3 WHERE IDDOC=@IdDoc
\}
