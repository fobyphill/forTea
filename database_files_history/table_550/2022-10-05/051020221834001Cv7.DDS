SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA9500 CURSOR FOR SELECT DEBKRED, SP9501, SP10397, SP10398, SP10399, SP10400, SP11267, SP9502, SP10401, SP10402, SP10403, SP10404, SP11276, SP11277  FROM RA9500 WHERE IDDOC=@IdDoc
OPEN Cur_RA9500
