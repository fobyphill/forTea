P=_1sp_RG1856_Change            |              |@per D,@p1 C(9),@p2 C(9),@p3 N(14,2),@p4 N(14,2)|{\
Set Nocount On
Update RG1856
  set SP1857=Case When ABS(SP1857+@p3)>999999999999.99 Then 999999999999.99 Else SP1857+@p3 End,SP2728=Case When ABS(SP2728+@p4)>999999999999.99 Then 999999999999.99 Else SP2728+@p4 End
  where PERIOD=@per AND SP1858=@p1 AND SP2723=@p2
if @@ROWCOUNT=0
    insert into RG1856 values(@per,@p1,@p2,@p3,@p4)
\}
