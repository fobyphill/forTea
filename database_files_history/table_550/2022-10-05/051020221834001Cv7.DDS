#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH6683_UpdateTotals      |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4),@Sum1 NUMERIC(28,4),@Sum2 NUMERIC(28,3),@Sum3 NUMERIC(28,4),@Sum4 NUMERIC(28,2),@Sum5 NUMERIC(28,3),@Sum6 NUMERIC(28,2) 
SELECT @Sum0=COALESCE(SUM(SP6674),0),@Sum1=COALESCE(SUM(SP6675),0),@Sum2=COALESCE(SUM(SP13550),0),@Sum3=COALESCE(SUM(SP13552),0),@Sum4=COALESCE(SUM(SP13553),0),@Sum5=COALESCE(SUM(SP13554),0),@Sum6=COALESCE(SUM(SP13555),0) FROM DT6683 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
    IF ABS(@Sum1)>9999999999.9999 SELECT @Sum1=9999999999.9999*SIGN(@Sum1)
    IF ABS(@Sum2)>99999999999.999 SELECT @Sum2=99999999999.999*SIGN(@Sum2)
    IF ABS(@Sum3)>9999999999.9999 SELECT @Sum3=9999999999.9999*SIGN(@Sum3)
    IF ABS(@Sum4)>999.99 SELECT @Sum4=999.99*SIGN(@Sum4)
    IF ABS(@Sum5)>99999999999.999 SELECT @Sum5=99999999999.999*SIGN(@Sum5)
    IF ABS(@Sum6)>999999999999.99 SELECT @Sum6=999999999999.99*SIGN(@Sum6)
UPDATE DH6683 SET SP6674=@Sum0,SP6675=@Sum1,SP13550=@Sum2,SP13552=@Sum3,SP13553=@Sum4,SP13554=@Sum5,SP13555=@Sum6 WHERE IDDOC=@IdDoc
\}
