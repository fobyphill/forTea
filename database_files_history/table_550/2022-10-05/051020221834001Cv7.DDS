P=_1sp_DH11012_UpdateTotals     |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,3) 
SELECT @Sum0=COALESCE(SUM(SP11009),0) FROM DT11012 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>99999999999.999 SELECT @Sum0=99999999999.999*SIGN(@Sum0)
UPDATE DH11012 SET SP11009=@Sum0 WHERE IDDOC=@IdDoc
\}
