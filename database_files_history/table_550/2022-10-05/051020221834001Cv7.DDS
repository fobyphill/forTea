DECLARE @Sum0 NUMERIC(28,2),@Sum1 NUMERIC(28,4) 
SELECT @Sum0=COALESCE(SUM(SP1479),0),@Sum1=COALESCE(SUM(SP1480),0) FROM DT1459 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>999999999999.99 SELECT @Sum0=999999999999.99*SIGN(@Sum0)
    IF ABS(@Sum1)>9999999999.9999 SELECT @Sum1=9999999999.9999*SIGN(@Sum1)
UPDATE DH1459 SET SP1479=@Sum0,SP1480=@Sum1 WHERE IDDOC=@IdDoc
\}
