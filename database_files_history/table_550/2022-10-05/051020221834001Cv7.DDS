# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG5118_TLockX            |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RG5118(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 662    : Регистр ПартииТоваровОтложенные
# Name    |Descr                         |SQLTableNam|RecordLock
T=RG5118  |Регистр ПартииТоваровОтложенны|RG5118     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP5106                |(P)Договор          |C   |13    |0        
F=SP5107                |(P)Партия           |C   |13    |0        
F=SP5108                |(P)Товар            |C   |9     |0        
F=SP5109                |(P)Количество       |N   |14    |3        
F=SP5110                |(P)Сумма            |N   |14    |4        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG5118                      |PERIOD+PROP   |1     |PERIOD,SP5106,SP5107,SP5108                                 |1          
I=VIA5107                        |VIA5107       |0     |PERIOD,SP5107                                               |0          
I=VIA5108                        |VIA5108       |0     |PERIOD,SP5108                                               |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG5118_Change            |              |@per D,@p1 C(13),@p2 C(13),@p3 C(9),@p4 N(14,3),@p5 N(14,4)|{\
Set Nocount On
Update RG5118
  set SP5109=Case When ABS(SP5109+@p4)>99999999999.999 Then 99999999999.999 Else SP5109+@p4 End,SP5110=Case When ABS(SP5110+@p5)>9999999999.9999 Then 9999999999.9999 Else SP5110+@p5 End
  where PERIOD=@per AND SP5106=@p1 AND SP5107=@p2 AND SP5108=@p3
if @@ROWCOUNT=0
    insert into RG5118 values(@per,@p1,@p2,@p3,@p4,@p5)
\}
