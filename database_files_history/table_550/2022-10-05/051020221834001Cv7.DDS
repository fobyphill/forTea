P=_1sp_RG6713_TLock             |EscalateTLock |                                        |set nocount on declare @i integer select @i=1 from RG6713(TABLOCK HOLDLOCK) where 0=1
#
#===============================================================================
#==PROCEDURE EscalateTLockX
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG6713_TLockX            |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RG6713(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 678    : Регистр ОВСбСумма
# Name    |Descr                         |SQLTableNam|RecordLock
T=RG6713  |Регистр ОВСбСумма             |RG6713     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP6708                |(P)Договор          |C   |13    |0        
F=SP6709                |(P)Партия           |C   |13    |0        
F=SP6710                |(P)Товар            |C   |9     |0        
F=SP6711                |(P)Сумма            |N   |14    |3        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG6713                      |PERIOD+PROP   |1     |PERIOD,SP6708,SP6709,SP6710                                 |1          
I=VIA6709                        |VIA6709       |0     |PERIOD,SP6709                                               |0          
I=VIA6710                        |VIA6710       |0     |PERIOD,SP6710                                               |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG6713_Change            |              |@per D,@p1 C(13),@p2 C(13),@p3 C(9),@p4 N(14,3)|{\
Set Nocount On
Update RG6713
  set SP6711=Case When ABS(SP6711+@p4)>99999999999.999 Then 99999999999.999 Else SP6711+@p4 End
  where PERIOD=@per AND SP6708=@p1 AND SP6709=@p2 AND SP6710=@p3
if @@ROWCOUNT=0
    insert into RG6713 values(@per,@p1,@p2,@p3,@p4)
\}
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
