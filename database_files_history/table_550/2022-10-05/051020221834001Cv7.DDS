    IF ABS(@Sum1)>99999999999.999 SELECT @Sum1=99999999999.999*SIGN(@Sum1)
    IF ABS(@Sum2)>9999999999.9999 SELECT @Sum2=9999999999.9999*SIGN(@Sum2)
    IF ABS(@Sum3)>9999999999.9999 SELECT @Sum3=9999999999.9999*SIGN(@Sum3)
    IF ABS(@Sum4)>9999999999.9999 SELECT @Sum4=9999999999.9999*SIGN(@Sum4)
UPDATE DH6376 SET SP6365=@Sum0,SP6366=@Sum1,SP6367=@Sum2,SP6370=@Sum3,SP6371=@Sum4 WHERE IDDOC=@IdDoc
\}
