  set SP901=Case When ABS(SP901+@p6)>99999999999.999 Then 99999999999.999 Else SP901+@p6 End,SP906=Case When ABS(SP906+@p7)>99999999999.999 Then 99999999999.999 Else SP906+@p7 End,SP3097=Case When ABS(SP3097+@p8)>9999999999.9999 Then 9999999999.9999 Else SP3097+@p8 End,SP3099=Case When ABS(SP3099+@p9)>9999999999.9999 Then 9999999999.9999 Else SP3099+@p9 End,SP3100=Case When ABS(SP3100+@p10)>999999999.999999999 Then 999999999.999999999 Else SP3100+@p10 End,SP3101=Case When ABS(SP3101+@p11)>999999999.999999999 Then 999999999.999999999 Else SP3101+@p11 End
  where PERIOD=@per AND SP897=@p1 AND SP898=@p2 AND SP3096=@p3 AND SP1640=@p4 AND SP5390=@p5
if @@ROWCOUNT=0
    insert into RG895 values(@per,@p1,@p2,@p3,@p4,@p5,@p6,@p7,@p8,@p9,@p10,@p11)
\}
