#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=IDDOC                 |ID Document's       |C   |9     |0        
F=LINENO_               |LineNo              |S   |0     |0        
F=ACTNO                 |Action No           |I   |0     |0        
F=DEBKRED               |Flag Debet/Kredit   |L   |0     |0        
F=IDDOCDEF              |ID Def Document     |I   |0     |0        
F=DATE_TIME_IDDOC       |Date+Time+IDDoc     |C   |23    |0        
F=SP5858                |(P)ПервичныйДокумент|C   |9     |0        
F=SP5859                |(P)Товар            |C   |9     |0        
F=SP5860                |(P)Склад            |C   |9     |0        
F=SP5861                |(P)СерНомер         |C   |100   |0        
F=SP5862                |(P)ДопНаименование  |C   |50    |0        
F=SP5863                |(P)Количество       |N   |9     |3        
F=SP5864                |(P)КоличествоСуб    |N   |9     |3        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA5865                      |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
I=VIA5858                        |VIA5858       |1     |SP5858,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
I=VIA5859                        |VIA5859       |1     |SP5859,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
