Update RG838
  set SP841=Case When ABS(SP841+@p8)>99999999999.999 Then 99999999999.999 Else SP841+@p8 End,SP905=Case When ABS(SP905+@p9)>99999999999.999 Then 99999999999.999 Else SP905+@p9 End,SP2962=Case When ABS(SP2962+@p10)>9999999999.9999 Then 9999999999.9999 Else SP2962+@p10 End,SP2963=Case When ABS(SP2963+@p11)>9999999999.9999 Then 9999999999.9999 Else SP2963+@p11 End,SP2968=Case When ABS(SP2968+@p12)>9999999999.9999 Then 9999999999.9999 Else SP2968+@p12 End,SP2970=Case When ABS(SP2970+@p13)>9999999999.9999 Then 9999999999.9999 Else SP2970+@p13 End,SP2969=Case When ABS(SP2969+@p14)>9999999999.9999 Then 9999999999.9999 Else SP2969+@p14 End,SP2972=Case When ABS(SP2972+@p15)>9999999999.9999 Then 9999999999.9999 Else SP2972+@p15 End
  where PERIOD=@per AND SP839=@p1 AND SP843=@p2 AND SP840=@p3 AND SP2855=@p4 AND SP2856=@p5 AND SP2857=@p6 AND SP2964=@p7
if @@ROWCOUNT=0
    insert into RG838 values(@per,@p1,@p2,@p3,@p4,@p5,@p6,@p7,@p8,@p9,@p10,@p11,@p12,@p13,@p14,@p15)
