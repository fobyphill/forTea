Set Nocount On
Update RG6899
  set SP6898=Case When ABS(SP6898+@p6)>9999999999.9999 Then 9999999999.9999 Else SP6898+@p6 End
  where PERIOD=@per AND SP6893=@p1 AND SP6894=@p2 AND SP6895=@p3 AND SP6896=@p4 AND SP6897=@p5
if @@ROWCOUNT=0
    insert into RG6899 values(@per,@p1,@p2,@p3,@p4,@p5,'',@p6)
\}
