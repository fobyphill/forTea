#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH10100_UpdateTotals     |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4),@Sum1 NUMERIC(28,4) 
SELECT @Sum0=COALESCE(SUM(SP10091),0),@Sum1=COALESCE(SUM(SP10092),0) FROM DT10100 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
    IF ABS(@Sum1)>9999999999.9999 SELECT @Sum1=9999999999.9999*SIGN(@Sum1)
UPDATE DH10100 SET SP10091=@Sum0,SP10092=@Sum1 WHERE IDDOC=@IdDoc
\}
#
