#==PROCEDURE EscalateTLock
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG1139_TLock             |EscalateTLock |                                        |set nocount on declare @i integer select @i=1 from RG1139(TABLOCK HOLDLOCK) where 0=1
#
#===============================================================================
#==PROCEDURE EscalateTLockX
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG1139_TLockX            |EscalateTLockX|                                        |set nocount on declare @i integer select @i=1 from RG1139(TABLOCKX HOLDLOCK) where 0=1
#
#===============================================================================
#==TABLE no 630    : Регистр ОтветственноеХранение
# Name    |Descr                         |SQLTableNam|RecordLock
T=RG1139  |Регистр ОтветственноеХранение |RG1139     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP1143                |(P)Договор          |C   |13    |0        
F=SP1141                |(P)Товар            |C   |9     |0        
F=SP1494                |(P)ГТД              |C   |30    |0        
F=SP2736                |(P)Страна           |C   |9     |0        
F=SP2737                |(P)Накладная        |C   |13    |0        
F=SP1142                |(P)Количество       |N   |14    |3        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG1139                      |PERIOD+PROP   |1     |PERIOD,SP1143,SP1141,SP1494,SP2736,SP2737                   |1          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG1139_Change            |              |@per D,@p1 C(13),@p2 C(9),@p3 C(30),@p4 C(9),@p5 C(13),@p6 N(14,3)|{\
Set Nocount On
Update RG1139
  set SP1142=Case When ABS(SP1142+@p6)>99999999999.999 Then 99999999999.999 Else SP1142+@p6 End
  where PERIOD=@per AND SP1143=@p1 AND SP1141=@p2 AND SP1494=@p3 AND SP2736=@p4 AND SP2737=@p5
if @@ROWCOUNT=0
    insert into RG1139 values(@per,@p1,@p2,@p3,@p4,@p5,@p6)
\}
