F=PERIOD                |Period Registr      |D   |0     |0        
F=SP8447                |(P)ДокументЗаявки   |C   |13    |0        
F=SP8227                |(P)ДокументДоговора |C   |13    |0        
F=SP8228                |(P)Товар            |C   |9     |0        
F=SP8229                |(P)Количество       |N   |14    |3        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG8230                      |PERIOD+PROP   |1     |PERIOD,SP8447,SP8227,SP8228                                 |1          
I=VIA8227                        |VIA8227       |0     |PERIOD,SP8227                                               |0          
I=VIA8228                        |VIA8228       |0     |PERIOD,SP8228                                               |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG8230_Change            |              |@per D,@p1 C(13),@p2 C(13),@p3 C(9),@p4 N(14,3)|{\
Set Nocount On
Update RG8230
  set SP8229=Case When ABS(SP8229+@p4)>99999999999.999 Then 99999999999.999 Else SP8229+@p4 End
  where PERIOD=@per AND SP8447=@p1 AND SP8227=@p2 AND SP8228=@p3
if @@ROWCOUNT=0
    insert into RG8230 values(@per,@p1,@p2,@p3,@p4)
\}
