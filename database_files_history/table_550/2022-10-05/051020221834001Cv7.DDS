    IF ABS(@Sum2)>999999999999.99 SELECT @Sum2=999999999999.99*SIGN(@Sum2)
UPDATE DH6885 SET SP6871=@Sum0,SP6872=@Sum1,SP6873=@Sum2 WHERE IDDOC=@IdDoc
