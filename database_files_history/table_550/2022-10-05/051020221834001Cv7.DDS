#==TABLE no 660    : Регистр ПоддерживаемыеОстатки
# Name    |Descr                         |SQLTableNam|RecordLock
T=RG4714  |Регистр ПоддерживаемыеОстатки |RG4714     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=PERIOD                |Period Registr      |D   |0     |0        
F=SP4711                |(P)Товар            |C   |9     |0        
F=SP4712                |(P)Склад            |C   |9     |0        
F=SP4830                |(P)Узел             |C   |9     |0        
F=SP4713                |(P)Количество       |N   |14    |3        
F=SP4928                |(P)КоличествоИ      |N   |14    |3        
F=SP4831                |(P)Скорость         |N   |7     |2        
F=SP5685                |(P)ПериодМ          |N   |4     |2        
F=SP7470                |(P)СкоростьК        |N   |7     |2        
F=SP11529               |(P)КоличествоР      |N   |14    |3        
F=SP11530               |(P)МинАй            |N   |14    |3        
F=SP11595               |(P)МаксАй           |N   |14    |3        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RG4714                      |PERIOD+PROP   |1     |PERIOD,SP4711,SP4712,SP4830                                 |1          
I=VIA4712                        |VIA4712       |0     |PERIOD,SP4712                                               |0          
I=VIA4830                        |VIA4830       |0     |PERIOD,SP4830                                               |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RG4714_Change            |              |@per D,@p1 C(9),@p2 C(9),@p3 C(9),@p4 N(14,3),@p5 N(14,3),@p6 N(7,2),@p7 N(4,2),@p8 N(7,2),@p9 N(14,3),@p10 N(14,3),@p11 N(14,3)|{\
Set Nocount On
Update RG4714
  set SP4713=Case When ABS(SP4713+@p4)>99999999999.999 Then 99999999999.999 Else SP4713+@p4 End,SP4928=Case When ABS(SP4928+@p5)>99999999999.999 Then 99999999999.999 Else SP4928+@p5 End,SP4831=Case When ABS(SP4831+@p6)>99999.99 Then 99999.99 Else SP4831+@p6 End,SP5685=Case When ABS(SP5685+@p7)>99.99 Then 99.99 Else SP5685+@p7 End,SP7470=Case When ABS(SP7470+@p8)>99999.99 Then 99999.99 Else SP7470+@p8 End,SP11529=Case When ABS(SP11529+@p9)>99999999999.999 Then 99999999999.999 Else SP11529+@p9 End,SP11530=Case When ABS(SP11530+@p10)>99999999999.999 Then 99999999999.999 Else SP11530+@p10 End,SP11595=Case When ABS(SP11595+@p11)>99999999999.999 Then 99999999999.999 Else SP11595+@p11 End
  where PERIOD=@per AND SP4711=@p1 AND SP4712=@p2 AND SP4830=@p3
if @@ROWCOUNT=0
    insert into RG4714 values(@per,@p1,@p2,@p3,@p4,@p5,@p6,@p7,@p8,@p9,@p10,@p11)
\}
