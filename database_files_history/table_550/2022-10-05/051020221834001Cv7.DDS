#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_DH12173_UpdateTotals     |              |@IdDoc C(9)                             |{\
SET NOCOUNT ON
DECLARE @Sum0 NUMERIC(28,4) 
SELECT @Sum0=COALESCE(SUM(SP12166),0) FROM DT12173 WHERE IDDOC=@IdDoc
    IF ABS(@Sum0)>9999999999.9999 SELECT @Sum0=9999999999.9999*SIGN(@Sum0)
UPDATE DH12173 SET SP12166=@Sum0 WHERE IDDOC=@IdDoc
\}
