#
#===============================================================================
#==TABLE no 715    : Регистр (Дв.) КомплектующиеДляПроизводства
# Name    |Descr                         |SQLTableNam|RecordLock
T=RA8230  |Регистр (Дв.) КомплектующиеДля|RA8230     |          
#-----Fields-------
# Name                  |Descr               |Type|Length|Precision
F=IDDOC                 |ID Document's       |C   |9     |0        
F=LINENO_               |LineNo              |S   |0     |0        
F=ACTNO                 |Action No           |I   |0     |0        
F=DEBKRED               |Flag Debet/Kredit   |L   |0     |0        
F=IDDOCDEF              |ID Def Document     |I   |0     |0        
F=DATE_TIME_IDDOC       |Date+Time+IDDoc     |C   |23    |0        
F=SP8447                |(P)ДокументЗаявки   |C   |13    |0        
F=SP8227                |(P)ДокументДоговора |C   |13    |0        
F=SP8228                |(P)Товар            |C   |9     |0        
F=SP8229                |(P)Количество       |N   |14    |3        
#----Indexes------
# Name                           |Descr         |Unique|Indexed fields                                              |Type       
I=PK_RA8230                      |of IDDOC+LineN|1     |IDDOC,LINENO_,ACTNO                                         |1          
I=VIA8447                        |VIA8447       |1     |SP8447,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
I=VIA8227                        |VIA8227       |1     |SP8227,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
I=VIA8228                        |VIA8228       |1     |SP8228,DATE_TIME_IDDOC,LINENO_,ACTNO                        |0          
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA8230_ClearRecalcDocActs|              |@IdDoc C(9), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I, @Direct I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char, @DebetCredit BIT
DECLARE @p0 CHAR(13), @p1 CHAR(13), @p2 CHAR(9), @f0 NUMERIC(14, 3)
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM
DECLARE Cur_RA8230 CURSOR FOR SELECT DEBKRED, SP8447, SP8227, SP8228, SP8229  FROM RA8230 WHERE IDDOC=@IdDoc
OPEN Cur_RA8230
FETCH NEXT FROM Cur_RA8230 INTO @DebetCredit, @p0, @p1, @p2, @f0
WHILE @@FETCH_STATUS=0 BEGIN

    IF @DebetCredit<>@Direct
        SELECT @f0=-@f0
    IF @RepeatToTM=1 BEGIN
        SELECT @Period=@CurPeriod
        WHILE @Period<=@PeriodTA BEGIN
            EXECUTE _1sp_RG8230_Change @Period, @p0, @p1, @p2, @f0
            EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
        END
    END
    ELSE
        EXECUTE _1sp_RG8230_Change @CurPeriod, @p0, @p1, @p2, @f0
    IF @SaveTurnsWithMonth=1 BEGIN
        EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
        EXECUTE _1sp_RG8230_Change @Period, @p0, @p1, @p2, @f0
    END

    FETCH NEXT FROM Cur_RA8230 INTO @DebetCredit, @p0, @p1, @p2, @f0
END
CLOSE Cur_RA8230
DEALLOCATE Cur_RA8230
\}
#
#===============================================================================
#==PROCEDURE 
# Name                          |Descr         |Parameters                              |Source                                                                          
P=_1sp_RA8230_WriteDocAct       |              |@IdDoc C(9), @LineNo S, @ActNo I, @DebetCredit L, @IdDocDef I, @DateTimeIdDoc C(23), @p0 C(13), @p1 C(13), @p2 C(9), @f0 N(14,3), @DocDate D, @CurPeriod D, @RepeatToTM I, @SaveTurnsWithMonth I|{\
SET NOCOUNT ON
DECLARE @PeriodTA datetime, @Period datetime, @SnapShotPeriod char
SELECT @PeriodTA=CURDATE, @SnapShotPeriod=SNAPSHPER FROM _1SSYSTEM

EXECUTE _1sp_GetBeginOfPeriod @PeriodTA, @SnapShotPeriod, @PeriodTA OUTPUT
INSERT INTO RA8230 VALUES(@IdDoc, @LineNo, @ActNo, @DebetCredit,@IdDocDef,@DateTimeIdDoc, @p0, @p1, @p2, @f0)
IF @DebetCredit=1
    SELECT @f0=-@f0
IF @RepeatToTM=1 BEGIN
    SELECT @Period=@CurPeriod
    WHILE @Period<=@PeriodTA BEGIN
        EXECUTE _1sp_RG8230_Change @Period, @p0, @p1, @p2, @f0
        EXECUTE _1sp_GetNextPeriod @Period, @SnapShotPeriod, @Period OUTPUT
    END
END
ELSE
    EXECUTE _1sp_RG8230_Change @CurPeriod, @p0, @p1, @p2, @f0
IF @SaveTurnsWithMonth=1 BEGIN
    EXECUTE _1sp_GetBeginOfPeriod @DocDate, 'M', @Period OUTPUT
    EXECUTE _1sp_RG8230_Change @Period, @p0, @p1, @p2, @f0
END
\}
