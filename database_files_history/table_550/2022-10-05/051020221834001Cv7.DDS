DECLARE @Sum0 NUMERIC(28,3),@Sum1 NUMERIC(28,3),@Sum2 NUMERIC(28,4),@Sum3 NUMERIC(28,4),@Sum4 NUMERIC(28,4) 
SELECT @Sum0=COALESCE(SUM(SP6365),0),@Sum1=COALESCE(SUM(SP6366),0),@Sum2=COALESCE(SUM(SP6367),0),@Sum3=COALESCE(SUM(SP6370),0),@Sum4=COALESCE(SUM(SP6371),0) FROM DT6376 WHERE IDDOC=@IdDoc
